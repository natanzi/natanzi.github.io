---
import * as Icons from 'lucide-astro';
import skillsData from '../../data/skills.json';

// Helper to safely render dynamic icons from lucide-astro by string name. 
// Falls back to "Code" if the name doesn't match an exported icon.
const getIcon = (iconName) => {
    return Icons[iconName] || Icons.Code;
};
---

<section id="skills" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
    <div class="flex items-center mb-12">
        <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
            <Icons.Cpu class="w-4 h-4 text-emerald-500" /> Skills & Tools
        </h2>
        <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {skillsData.categories && skillsData.categories.map((category) => {
            const IconComponent = getIcon(category.icon);
            return (
                <div class="p-6 md:p-8 rounded-3xl bg-white/70 dark:bg-zinc-900/40 backdrop-blur-md border border-zinc-200 dark:border-zinc-800/60 shadow-sm hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgb(0,0,0,0.2)] hover:border-zinc-300 dark:hover:border-zinc-700/80 transition-all duration-300 group">
                    <div class="flex items-center mb-6">
                        <div class="p-3.5 rounded-2xl bg-zinc-100 dark:bg-zinc-800 shadow-inner mr-4 text-zinc-700 dark:text-zinc-300 group-hover:text-blue-600 dark:group-hover:text-emerald-400 group-hover:-translate-y-1 transition-all duration-300">
                            <IconComponent class="w-5 h-5" />
                        </div>
                        <h3 class="text-xl font-bold font-montserrat text-zinc-900 dark:text-zinc-100 tracking-tight">{category.category}</h3>
                    </div>
                    
                    <div class="flex flex-wrap gap-2.5">
                        {category.skills && category.skills.map((skill) => (
                            <span class="px-3.5 py-1.5 text-[13px] font-semibold tracking-wide text-zinc-700 dark:text-zinc-300 bg-zinc-50 dark:bg-zinc-800/50 border border-zinc-200/80 dark:border-zinc-700/50 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors cursor-default hover:text-blue-700 dark:hover:text-emerald-300">
                                {skill.name}
                            </span>
                        ))}
                    </div>
                </div>
            );
        })}
    </div>
</section>
