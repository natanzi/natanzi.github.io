---
import { Activity, ArrowUpRight } from 'lucide-astro';
import newsData from '../../data/news.json';
---

{newsData.news && newsData.news.length > 0 && (
    <section id="news" class="mb-32 animate-fade-up scroll-mt-24">
        <div class="flex items-center mb-10">
            <Activity class="w-6 h-6 text-zinc-400 dark:text-zinc-500 mr-3" />
            <h2 class="text-3xl font-serif text-zinc-900 dark:text-zinc-100">News & Updates</h2>
        </div>
        
        <div class="bg-white dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-6 sm:p-8 shadow-sm">
            <ul class="space-y-6">
                {newsData.news.map((item, index) => (
                    <li class={`flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 ${index !== newsData.news.length - 1 ? 'pb-6 border-b border-zinc-100 dark:border-zinc-800/80' : ''}`}>
                        <span class="text-sm font-semibold tracking-wide text-blue-600 dark:text-blue-400 shrink-0 w-24">
                            {item.date}
                        </span>
                        <div class="flex-1 text-zinc-700 dark:text-zinc-300 text-base leading-relaxed font-light">
                            {item.link ? (
                                <a href={item.link} target={item.link.startsWith('http') ? "_blank" : "_self"} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors inline-block group">
                                    {item.content}
                                    <ArrowUpRight class="w-3.5 h-3.5 inline-block text-zinc-400 group-hover:text-blue-500 ml-1 mb-0.5 transition-colors" />
                                </a>
                            ) : (
                                <span>{item.content}</span>
                            )}
                        </div>
                    </li>
                ))}
            </ul>
        </div>
    </section>
)}
