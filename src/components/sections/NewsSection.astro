---
import { Activity, ArrowUpRight } from 'lucide-astro';
import newsData from '../../data/news.json';
---

{newsData.news && newsData.news.length > 0 && (
    <section id="news" class="mb-32 animate-fade-up scroll-mt-24">
        <div class="flex items-center mb-8">
            <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
                <Activity class="w-4 h-4 text-blue-500" /> News & Updates
            </h2>
            <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
        </div>
        
        <div class="pl-4 md:pl-0">
            <ul class="flex flex-col gap-4">
                {newsData.news.map((item) => (
                    <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-6 group">
                        <span class="text-xs sm:text-sm pt-0.5 font-semibold tracking-wider text-zinc-400 dark:text-zinc-500 shrink-0 w-24 uppercase">
                            {item.date}
                        </span>
                        <div class="flex-1 text-zinc-800 dark:text-zinc-200 text-base leading-relaxed font-light">
                            {item.link ? (
                                <a href={item.link} target={item.link.startsWith('http') ? "_blank" : "_self"} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors inline-block">
                                    {item.content}
                                    <ArrowUpRight class="w-3 h-3 inline-block text-zinc-300 dark:text-zinc-600 hover:text-blue-500 ml-1 mb-0.5 transition-colors" />
                                </a>
                            ) : (
                                <span>{item.content}</span>
                            )}
                        </div>
                    </li>
                ))}
            </ul>
        </div>
    </section>
)}
