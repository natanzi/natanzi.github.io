---
import { Cpu, Radio, ArrowUpRight, ShieldAlert, Network, Activity } from 'lucide-astro';
---

<section id="projects" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
    <div class="flex items-center mb-12">
        <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
            <Cpu class="w-4 h-4 text-emerald-500" /> Selected Works
        </h2>
        <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Project 1 -->
        <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
            <div>
                <div class="flex items-center justify-between mb-6">
                    <div class="p-3 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-xl border border-blue-100 dark:border-blue-800/50">
                        <Radio class="w-6 h-6" />
                    </div>
                    <div class="w-10 h-10 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 flex items-center justify-center group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:border-zinc-900 dark:group-hover:border-zinc-100 transition-colors shadow-sm">
                        <ArrowUpRight class="w-5 h-5 text-zinc-400 dark:text-zinc-500 group-hover:text-white dark:group-hover:text-zinc-900 transition-colors" />
                    </div>
                </div>
                <h3 class="text-2xl font-medium text-zinc-900 dark:text-zinc-100 mb-3">WeaveMind</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed font-light mb-8 text-base md:text-lg">
                    A novel pattern-driven beamforming architecture designed for 6G environments. It utilizes Local Context Memory and Stability Anchors to dramatically improve signal reliability and targeting in high-density areas.
                </p>
            </div>
            <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 dark:border-zinc-800/50 pt-6">
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">Python</span>
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">PyTorch</span>
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">MATLAB</span>
            </div>
        </a>

        <!-- Project 2 -->
        <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
            <div>
                <div class="flex items-center justify-between mb-6">
                    <div class="p-3 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-xl border border-emerald-100 dark:border-emerald-800/50">
                        <ShieldAlert class="w-6 h-6" />
                    </div>
                    <div class="w-10 h-10 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 flex items-center justify-center group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:border-zinc-900 dark:group-hover:border-zinc-100 transition-colors shadow-sm">
                        <ArrowUpRight class="w-5 h-5 text-zinc-400 dark:text-zinc-500 group-hover:text-white dark:group-hover:text-zinc-900 transition-colors" />
                    </div>
                </div>
                <h3 class="text-2xl font-medium text-zinc-900 dark:text-zinc-100 mb-3">AI-Driven Fuzzing</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed font-light mb-8 text-base md:text-lg">
                    A highly scalable framework for vulnerability analysis in 5G traffic steering algorithms. It employs NSGA-II multi-objective optimization to isolate hidden protocol weaknesses before they compromise network stability.
                </p>
            </div>
            <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 dark:border-zinc-800/50 pt-6">
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">Security</span>
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">Optimization</span>
            </div>
        </a>

        <!-- Project 3 -->
        <a href="https://github.com/natanzi" target="_blank" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
            <div>
                <div class="flex items-center justify-between mb-6">
                    <div class="p-3 bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-xl border border-purple-100 dark:border-purple-800/50">
                        <Network class="w-6 h-6" />
                    </div>
                    <div class="w-10 h-10 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 flex items-center justify-center group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:border-zinc-900 dark:group-hover:border-zinc-100 transition-colors shadow-sm">
                        <ArrowUpRight class="w-5 h-5 text-zinc-400 dark:text-zinc-500 group-hover:text-white dark:group-hover:text-zinc-900 transition-colors" />
                    </div>
                </div>
                <h3 class="text-2xl font-medium text-zinc-900 dark:text-zinc-100 mb-3">ORION</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed font-light mb-8 text-base md:text-lg">
                    Open-source architecture for dynamic RAN slicing in 6G. Employs deep reinforcement learning to dynamically allocate spectrum across distinct network slices, dramatically improving bandwidth efficiency.
                </p>
            </div>
            <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 dark:border-zinc-800/50 pt-6">
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">O-RAN</span>
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">Reinforcement Learning</span>
            </div>
        </a>

        <!-- Project 4 -->
        <a href="https://github.com/natanzi" target="_blank" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
            <div>
                <div class="flex items-center justify-between mb-6">
                    <div class="p-3 bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 rounded-xl border border-rose-100 dark:border-rose-800/50">
                        <Activity class="w-6 h-6" />
                    </div>
                    <div class="w-10 h-10 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 flex items-center justify-center group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:border-zinc-900 dark:group-hover:border-zinc-100 transition-colors shadow-sm">
                        <ArrowUpRight class="w-5 h-5 text-zinc-400 dark:text-zinc-500 group-hover:text-white dark:group-hover:text-zinc-900 transition-colors" />
                    </div>
                </div>
                <h3 class="text-2xl font-medium text-zinc-900 dark:text-zinc-100 mb-3">FairShare</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed font-light mb-8 text-base md:text-lg">
                    A decentralized resource sharing protocol for edge devices. Utilizes federated learning to allow edge clusters to cooperatively manage power limits without central cloud orchestrators.
                </p>
            </div>
            <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 dark:border-zinc-800/50 pt-6">
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">Edge Computing</span>
                <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">Federated Learning</span>
            </div>
        </a>
    </div>
</section>
