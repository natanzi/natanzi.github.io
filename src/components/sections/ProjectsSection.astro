---
import * as Icons from 'lucide-astro';
import { Cpu, ArrowUpRight } from 'lucide-astro';
import projectsData from '../../data/projects.json';

const getIcon = (iconName) => {
    return Icons[iconName] || Icons.Code;
};

const colors = [
    {
        bg: "bg-blue-50 dark:bg-blue-900/30",
        text: "text-blue-600 dark:text-blue-400",
        border: "border-blue-100 dark:border-blue-800/50"
    },
    {
        bg: "bg-emerald-50 dark:bg-emerald-900/30",
        text: "text-emerald-600 dark:text-emerald-400",
        border: "border-emerald-100 dark:border-emerald-800/50"
    },
    {
        bg: "bg-purple-50 dark:bg-purple-900/30",
        text: "text-purple-600 dark:text-purple-400",
        border: "border-purple-100 dark:border-purple-800/50"
    },
    {
        bg: "bg-rose-50 dark:bg-rose-900/30",
        text: "text-rose-600 dark:text-rose-400",
        border: "border-rose-100 dark:border-rose-800/50"
    }
];

const getColorTheme = (index) => {
    return colors[index % colors.length];
};
---

<section id="projects" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
    <div class="flex items-center justify-between mb-12">
        <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
            <Cpu class="w-4 h-4 text-emerald-500" /> Selected Works
        </h2>
        <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow mr-6"></div>
        <a href="/projects" class="text-xs font-semibold text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors uppercase tracking-wider whitespace-nowrap flex items-center gap-1 group">
            Project Menu <ArrowUpRight class="w-3.5 h-3.5 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-transform" />
        </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projectsData.projects && projectsData.projects.map((project, index) => {
            const IconComponent = getIcon(project.icon);
            const theme = getColorTheme(index);
            return (
                <a 
                    href={project.url} 
                    target={project.url.startsWith('http') ? "_blank" : undefined} 
                    rel={project.url.startsWith('http') ? "noopener noreferrer" : undefined} 
                    class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8"
                >
                    <div>
                        <div class="flex items-center justify-between mb-6">
                            <div class={`p-3 rounded-xl border ${theme.bg} ${theme.text} ${theme.border}`}>
                                <IconComponent class="w-6 h-6" />
                            </div>
                            <div class="w-10 h-10 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 flex items-center justify-center group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:border-zinc-900 dark:group-hover:border-zinc-100 transition-colors shadow-sm">
                                <ArrowUpRight class="w-5 h-5 text-zinc-400 dark:text-zinc-500 group-hover:text-white dark:group-hover:text-zinc-900 transition-colors" />
                            </div>
                        </div>
                        <h3 class="text-2xl font-medium text-zinc-900 dark:text-zinc-100 mb-3">{project.title}</h3>
                        <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed font-light mb-8 text-base md:text-lg">
                            {project.description}
                        </p>
                    </div>
                    <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 dark:border-zinc-800/50 pt-6">
                        {project.tags && project.tags.map((tag) => (
                            <span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">
                                {tag}
                            </span>
                        ))}
                    </div>
                </a>
            );
        })}
    </div>
</section>
