---
import { ArrowRight } from 'lucide-astro';

// Load all markdown files from the blog directory
const postImportResult = import.meta.glob('../../content/blog/**/*.md', { eager: true });
const posts = Object.values(postImportResult) as any[];

// Sort posts by date descending and get the top 3
posts.sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
const recentPosts = posts.slice(0, 3);
---

<section id="blog" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-12 gap-4">
        <div class="flex items-center flex-grow">
            <h2 class="text-xl md:text-2xl font-bold font-montserrat text-zinc-900 dark:text-zinc-100 flex items-center gap-2">
                Recent Blog Post
            </h2>
            <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
        </div>
        <a href="/blog" class="inline-flex items-center text-sm font-semibold text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group">
            View All Posts <ArrowRight class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" />
        </a>
    </div>

    {/* Blog Cards Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 text-left border-t border-zinc-100 dark:border-zinc-800/60 pt-10">
        {
            recentPosts.map((post) => {
                const slug = post.file.split('/').pop().split('.').shift();
                const heroImage = post.frontmatter.image || "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=800&auto=format&fit=crop";
                return (
                    <a href={`/blog/${slug}`} class="group flex flex-col bg-white dark:bg-zinc-900/40 rounded-2xl overflow-hidden hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgb(0,0,0,0.2)] transition-shadow border border-zinc-100 dark:border-zinc-800/80">
                        <div class="aspect-[4/3] overflow-hidden bg-zinc-100 dark:bg-zinc-800">
                            <img src={heroImage} alt={post.frontmatter.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        </div>
                        <div class="p-5 md:p-6 flex flex-col flex-grow">
                            <span class="text-[10px] font-bold tracking-wider text-blue-500 uppercase mb-2 block">{post.frontmatter.category || "Research"}</span>
                            <h4 class="text-lg font-bold font-montserrat text-zinc-900 dark:text-zinc-100 mb-3 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                {post.frontmatter.title}
                            </h4>
                            <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed line-clamp-2 mt-auto">
                                {post.frontmatter.description}
                            </p>
                        </div>
                    </a>
                );
            })
        }
    </div>
</section>
