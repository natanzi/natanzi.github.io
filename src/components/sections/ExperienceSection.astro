---
import { Briefcase } from 'lucide-astro';
import experienceData from '../../data/experience.json';
---

<section id="experience" class="mb-32 animate-fade-up delay-100 scroll-mt-24">
    <div class="flex items-center mb-12">
        <h2 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest flex items-center gap-2">
            <Briefcase class="w-4 h-4 text-blue-500" /> Experience
        </h2>
        <div class="ml-6 h-px bg-zinc-200 flex-grow"></div>
    </div>
    
    <div class="space-y-12 pl-4 md:pl-0">
        {experienceData.experience.map((role, index) => {
            const isAcademic = role.type === 'academic';
            return (
                <div class="relative pl-8 md:pl-0 md:grid md:grid-cols-4 md:items-baseline md:gap-8">
                    {/* Mobile timeline line */}
                    <div class={`absolute left-0 top-2 bottom-0 w-px md:hidden ${isAcademic ? 'bg-blue-200 dark:bg-blue-900/50' : 'bg-zinc-200 dark:bg-zinc-800'}`}></div>
                    <div class={`absolute md:hidden border-2 ${isAcademic 
                        ? 'left-[-5px] top-2 w-2.5 h-2.5 rounded-full bg-blue-500 dark:bg-blue-400 border-[#fafafa] dark:border-zinc-950 shadow-sm' 
                        : 'left-[-4px] top-2 w-2 h-2 rounded-full bg-zinc-400 dark:bg-zinc-600 border-[#fafafa] dark:border-zinc-950'}`}></div>
                    
                    {/* Desktop accent */}
                    <div class={`md:col-span-1 w-12 mb-4 hidden md:block relative border-t-2 ${isAcademic ? 'border-blue-500 dark:border-blue-400' : 'border-zinc-300 dark:border-zinc-700'}`}>
                        <div class={`absolute top-[-4px] w-2 h-2 rounded-full ${isAcademic ? 'right-[-4px] top-[-5px] w-2 h-2 bg-blue-500 dark:bg-blue-400' : 'right-[-3px] top-[-4px] w-1.5 h-1.5 bg-zinc-400 dark:bg-zinc-600'}`}></div>
                    </div>

                    <div class={`md:col-span-3 ${index < experienceData.experience.length - 1 ? 'pb-10 border-b border-zinc-100/80 dark:border-zinc-800/80' : 'pb-4'}`}>
                        <div class="flex flex-col md:flex-row md:justify-between md:items-baseline mb-2">
                            <h3 class="text-xl md:text-2xl font-semibold text-zinc-900 dark:text-zinc-100">{role.title}</h3>
                            <span class="inline-block py-1 px-3 rounded-full bg-zinc-100 dark:bg-zinc-800 text-xs text-zinc-600 dark:text-zinc-400 font-semibold tabular-nums mt-2 md:mt-0 w-max">{role.period}</span>
                        </div>
                        <div class={`text-sm md:text-base mb-4 font-serif italic ${isAcademic ? 'text-blue-600 dark:text-blue-400' : 'text-zinc-500 dark:text-zinc-400'}`}>{role.company}</div>
                        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-light text-base md:text-lg">{role.description}</p>
                    </div>
                </div>
            );
        })}
    </div>
</section>
