---
import { Briefcase, GraduationCap, MapPin } from 'lucide-astro';
import experienceData from '../../data/experience.json';
---

<section id="experience" class="mb-32 animate-fade-up delay-100 scroll-mt-24">
    <div class="flex items-center mb-16">
        <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
            <Briefcase class="w-4 h-4 text-blue-500" /> Experience
        </h2>
        <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
    </div>
    
    <div class="relative max-w-4xl mx-auto">
        {/* Continuous Vertical Line */}
        <div class="absolute left-4 md:left-[25%] top-2 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800"></div>

        <div class="space-y-12">
            {experienceData.experience.map((role, index) => {
                const isAcademic = role.type === 'academic';
                return (
                    <div class="relative flex flex-col md:flex-row group">
                        
                        {/* Interactive Line Fill Effect */}
                        {index !== experienceData.experience.length - 1 && (
                            <div class="absolute left-4 md:left-[25%] top-8 bottom-[-3rem] w-px bg-blue-500 scale-y-0 origin-top group-hover:scale-y-100 transition-transform duration-500 ease-out z-0"></div>
                        )}

                        {/* Date - Left Column */}
                        <div class="md:w-1/4 md:pr-12 md:text-right pt-2 mb-2 md:mb-0 pl-12 md:pl-0 flex-shrink-0">
                            <span class="text-xs sm:text-[13px] font-bold tracking-widest text-zinc-400 dark:text-zinc-500 uppercase group-hover:text-blue-500 transition-colors duration-300">
                                {role.period}
                            </span>
                        </div>

                        {/* Node Icon */}
                        <div class="absolute left-0 md:left-[25%] md:-translate-x-1/2 top-0 w-8 h-8 rounded-full border-[3px] border-zinc-50 dark:border-zinc-950 bg-white dark:bg-zinc-900 shadow-[0_0_0_1px_rgba(0,0,0,0.08)] dark:shadow-[0_0_0_1px_rgba(255,255,255,0.1)] flex items-center justify-center group-hover:bg-blue-50 flex-shrink-0 dark:group-hover:bg-blue-900/40 group-hover:shadow-[0_0_0_1px_#3b82f6] transition-all duration-300 z-10">
                            {isAcademic ? (
                                <GraduationCap class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300" />
                            ) : (
                                <Briefcase class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300" />
                            )}
                        </div>

                        {/* Content - Right Column */}
                        <div class="md:w-3/4 pl-12 md:pl-10 pb-2">
                            <h3 class="text-xl md:text-2xl font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300 mb-1">
                                {role.title}
                            </h3>
                            <div class="text-[15px] font-serif italic text-zinc-500 dark:text-zinc-400 mb-4 flex items-center gap-1.5">
                                <MapPin class="w-3.5 h-3.5 text-zinc-400 group-hover:text-blue-400 transition-colors" /> {role.company}
                            </div>
                            <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-light text-[15px] md:text-base">
                                {role.description}
                            </p>
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</section>
