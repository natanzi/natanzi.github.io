---
import '../styles/global.css';
import { ArrowLeft, Sun, Moon, Twitter, Facebook, Link as LinkIcon, Linkedin, Mail } from 'lucide-astro';

const { frontmatter } = Astro.props;

// Fetch related posts
const allPosts = await Astro.glob('../content/blog/*.md');
const relatedPosts = allPosts
    .filter(post => post.frontmatter.title !== frontmatter.title)
    .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf())
    .slice(0, 3);

// Fallback image if not provided
const heroImage = frontmatter.image || "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=2000&auto=format&fit=crop";
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{frontmatter.title} | Milad Natanzi</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content={frontmatter.description}>
    <meta name="author" content="Milad Natanzi">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article">
    <meta property="og:title" content={frontmatter.title}>
    <meta property="og:description" content={frontmatter.description}>
    <meta property="og:image" content={heroImage}>
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content={frontmatter.title}>
    <meta property="twitter:description" content={frontmatter.description}>
    <meta property="twitter:image" content={heroImage}>

    <!-- Google Fonts: Inter, Newsreader, Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Newsreader', serif; }
        .font-montserrat { font-family: 'Montserrat', sans-serif; }
        
        .glass-nav {
            background: rgba(250, 250, 250, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .dark .glass-nav {
            background: rgba(9, 9, 11, 0.9);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.03) 0%, rgba(250, 250, 250, 0) 70%);
        }
        
        .dark .bg-glow::before {
            background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, rgba(9, 9, 11, 0) 70%);
        }

        /* ── Modern Typography for Markdown Prose ── */
        .prose h2 {
            font-family: 'Newsreader', serif;
            font-size: 2.25rem;
            font-weight: 600;
            color: #18181b;
            margin-top: 3.5rem;
            margin-bottom: 1.5rem;
            line-height: 1.2;
        }
        .dark .prose h2 { color: #f4f4f5; }
        
        .prose h3 {
            font-family: 'Inter', sans-serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: #27272a;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
        }
        .dark .prose h3 { color: #e4e4e7; }
        
        .prose p {
            color: #3f3f46; /* zinc-700 */
            line-height: 1.8;
            font-weight: 400;
            font-size: 1.125rem;
            margin-bottom: 1.75rem;
        }
        .dark .prose p { color: #a1a1aa; /* zinc-400 */ }
        
        .prose strong {
            font-weight: 700;
            color: #18181b;
        }
        .dark .prose strong { color: #e4e4e7; }
        
        .prose ul, .prose ol {
            color: #3f3f46;
            line-height: 1.8;
            font-weight: 400;
            font-size: 1.125rem;
            margin-bottom: 1.75rem;
            padding-left: 1.5rem;
        }
        .dark .prose ul, .dark .prose ol { color: #a1a1aa; }
        
        .prose li {
            margin-bottom: 0.5rem;
            list-style-type: disc;
        }
        
        .prose blockquote {
            border-left: 4px solid #06b6d4; /* teal-500 matching the mockup */
            padding-left: 2rem;
            margin: 3rem 0;
            font-family: 'Newsreader', serif;
            font-weight: 600;
            font-size: 1.75rem;
            line-height: 1.4;
            color: #18181b;
        }
        .dark .prose blockquote {
            color: #f4f4f5;
            border-left-color: #22d3ee; /* teal-400 */
        }
        
        .prose a {
            color: #2563eb;
            text-decoration: underline;
            text-decoration-color: transparent;
            transition: text-decoration-color 0.2s;
        }
        .prose a:hover {
            text-decoration-color: #2563eb;
        }
        .dark .prose a {
            color: #60a5fa;
        }
        .dark .prose a:hover {
            text-decoration-color: #60a5fa;
        }

        .prose code {
            background-color: rgba(0,0,0,0.05);
            padding: 0.2em 0.4em;
            border-radius: 0.25rem;
            font-size: 0.875em;
            color: #ef4444; /* red-500 */
        }
        .dark .prose code {
            background-color: rgba(255,255,255,0.1);
            color: #fca5a5;
        }
        .prose pre {
            background-color: #18181b !important;
            padding: 1.25rem;
            border-radius: 0.75rem;
            overflow-x: auto;
            margin-bottom: 1.75rem;
        }
        .prose pre code {
            background-color: transparent;
            color: #e4e4e7;
            padding: 0;
        }
    </style>
    
    <!-- Initialize Theme Script -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-white dark:bg-[#0a0a0b] text-zinc-900 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300">

    <div class="bg-glow"></div>

    <!-- Navigation (Refined for editorial look) -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-2 text-[11px] font-bold tracking-widest text-zinc-500 uppercase overflow-hidden whitespace-nowrap text-ellipsis mr-4">
                <a href="/" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Home page</a>
                <span class="text-zinc-300 dark:text-zinc-700">›</span>
                <a href="/blog" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Blog</a>
                <span class="text-zinc-300 dark:text-zinc-700">›</span>
                <span class="text-blue-500 truncate max-w-[150px] sm:max-w-xs block">{frontmatter.category}</span>
            </div>
            
            <div class="flex items-center space-x-4 shrink-0">
                <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800 bg-zinc-50 dark:bg-zinc-900">
                    <Sun class="hidden dark:block w-3.5 h-3.5" />
                    <Moon class="block dark:hidden w-3.5 h-3.5" />
                </button>
            </div>
        </div>
    </nav>

    <main class="w-full pt-32 pb-24 md:pt-40 md:pb-32">
        <article>
            <!-- Header Section (Centered) -->
            <header class="max-w-4xl mx-auto px-6 text-center mb-12">
                <div class="text-[10px] md:text-xs font-bold tracking-widest text-zinc-500 dark:text-zinc-400 uppercase mb-6 flex justify-center items-center">
                    <span>{frontmatter.category}</span>
                    <span class="mx-3 text-zinc-300 dark:text-zinc-700">|</span>
                    <span>{frontmatter.date.toUpperCase()}</span>
                </div>
                
                <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[4rem] font-serif font-medium text-zinc-900 dark:text-white leading-[1.15] mb-8 tracking-tight max-w-4xl mx-auto">
                    {frontmatter.title}
                </h1>
                
                <p class="text-sm font-semibold text-zinc-600 dark:text-zinc-400 font-inter">
                    by <span class="text-zinc-900 dark:text-zinc-100">Milad Natanzi</span>
                </p>
            </header>

            <!-- Hero Image & Share (Wide) -->
            <div class="max-w-5xl mx-auto px-6 mb-16">
                <!-- Top Share Bar -->
                <div class="flex items-center justify-between mb-4 mt-12 border-b border-zinc-100 dark:border-zinc-800/60 pb-4">
                    <span class="text-xs font-bold tracking-wider text-zinc-900 dark:text-zinc-100">Share this article</span>
                    <div class="flex items-center gap-4 text-zinc-500 dark:text-zinc-400">
                        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}`} target="_blank" class="flex items-center hover:text-blue-500 transition-colors text-[11px] font-medium tracking-wide">
                            <Twitter class="w-3.5 h-3.5 mr-1.5" /> Tweet
                        </a>
                        <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent('https://natanzi.com/blog/' + frontmatter.title)}`} target="_blank" class="flex items-center hover:text-blue-700 dark:hover:text-blue-500 transition-colors text-[11px] font-medium tracking-wide">
                            <Linkedin class="w-3.5 h-3.5 mr-1.5" /> Share
                        </a>
                        <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!');" class="flex items-center hover:text-zinc-900 dark:hover:text-white transition-colors text-[11px] font-medium tracking-wide">
                            <LinkIcon class="w-3.5 h-3.5 mr-1.5" /> Copy
                        </button>
                    </div>
                </div>

                <!-- Hero Image -->
                <div class="w-full aspect-[21/9] md:aspect-[2.35/1] overflow-hidden bg-zinc-100 dark:bg-zinc-900">
                    <img src={heroImage} alt={frontmatter.title} class="w-full h-full object-cover grayscale-[10%]" />
                </div>
            </div>

            <!-- Main Content (Narrow) -->
            <div class="max-w-[700px] mx-auto px-6 prose prose-lg prose-zinc dark:prose-invert">
                <slot />
            </div>

            <!-- Footer Meta (Tags & Bottom Share) -->
            <div class="max-w-[700px] mx-auto px-6 mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800">
                <!-- Tags -->
                {frontmatter.tags && frontmatter.tags.length > 0 && (
                    <div class="mb-12">
                        <span class="block text-[11px] font-bold tracking-widest text-zinc-500 uppercase mb-3">Tags</span>
                        <div class="flex flex-wrap gap-2">
                            <span class="px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-xs font-semibold rounded-sm border border-blue-100 dark:border-blue-800/30 tracking-wide uppercase">
                                {frontmatter.category}
                            </span>
                            {frontmatter.tags.map(tag => (
                                <span class="px-3 py-1 bg-zinc-100 dark:bg-zinc-800/50 text-zinc-600 dark:text-zinc-300 text-xs font-semibold rounded-sm border border-zinc-200 dark:border-zinc-700 tracking-wide uppercase">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>
                )}
                
                <!-- Bottom Centered Share -->
                <div class="text-center pt-8 border-t border-zinc-100 dark:border-zinc-800/50">
                    <p class="text-xs font-bold tracking-widest text-zinc-900 dark:text-zinc-100 mb-6">Share this article</p>
                    <div class="flex items-center justify-center gap-6 text-zinc-500 dark:text-zinc-400">
                        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}`} target="_blank" class="flex items-center hover:text-blue-500 transition-colors text-xs font-medium tracking-wide">
                            <Twitter class="w-4 h-4 mr-2" /> Tweet
                        </a>
                        <a href={`mailto:?subject=${encodeURIComponent(frontmatter.title)}&body=Read this article by Milad Natanzi`} class="flex items-center hover:text-red-500 transition-colors text-xs font-medium tracking-wide">
                            <Mail class="w-4 h-4 mr-2" /> Email
                        </a>
                        <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!');" class="flex items-center hover:text-zinc-900 dark:hover:text-white transition-colors text-xs font-medium tracking-wide">
                            <LinkIcon class="w-4 h-4 mr-2" /> Copy Link
                        </button>
                    </div>
                </div>
            </div>
        </article>
    </main>

    <!-- Related Articles Section -->
    <section class="max-w-6xl mx-auto px-6 py-24 border-t border-zinc-200 dark:border-zinc-800">
        <div class="flex justify-between items-end mb-10 pb-4 border-b border-zinc-200 dark:border-zinc-800">
            <h3 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 font-montserrat tracking-tight">Related Articles</h3>
            <a href="/blog" class="text-[13px] font-bold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors uppercase tracking-widest mb-1">View All</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
            {relatedPosts.map(post => (
                <a href={post.url} class="group flex flex-col bg-transparent">
                    <div class="aspect-[4/3] overflow-hidden bg-zinc-100 dark:bg-zinc-800 mb-5 relative">
                        <img src={post.frontmatter.image || "https://images.unsplash.com/photo-1555949963-aa79dcee981c?auto=format&fit=crop&q=80&w=800&h=600"} alt={post.frontmatter.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        <div class="absolute inset-0 ring-1 ring-inset ring-black/10 dark:ring-white/10"></div>
                    </div>
                    <div class="flex flex-col flex-grow">
                        <div class="flex items-center text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-3">
                            <span class="text-blue-600 dark:text-blue-400">{post.frontmatter.category}</span>
                            <span class="mx-2">|</span>
                            <span>{post.frontmatter.date.toUpperCase()}</span>
                        </div>
                        <h4 class="text-lg font-bold font-montserrat text-zinc-900 dark:text-zinc-100 mb-3 leading-[1.4] group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                            {post.frontmatter.title}
                        </h4>
                        <span class="text-[13px] font-bold text-blue-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 mt-auto opacity-0 group-hover:opacity-100 transition-opacity">
                            Read Now →
                        </span>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <!-- Minimal Footer -->
    <footer class="py-12 border-t border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-[#050505]">
        <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center text-[13px] font-medium text-zinc-500 dark:text-zinc-400">
            <div class="mb-4 sm:mb-0">
                <span class="font-bold text-zinc-900 dark:text-zinc-100">Milad Natanzi</span> © 2026. All rights reserved.
            </div>
            <div class="flex gap-6">
                <a href="/" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Home</a>
                <a href="#about" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">About</a>
                <a href="mailto:milad@natanzi.com" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Contact</a>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script>
        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('theme-toggle');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', function() {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                }
            });
        }
    </script>
</body>
</html>
