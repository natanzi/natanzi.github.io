---
import '../styles/global.css';

const { frontmatter } = Astro.props;
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{frontmatter.title} | Milad.</title>
    <!-- Google Fonts: Inter & Newsreader -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { 
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
        }
        .font-serif {
            font-family: 'Newsreader', serif;
        }
        
        .glass-nav {
            background: rgba(250, 250, 250, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, rgba(250, 250, 250, 0) 70%);
        }

        /* Typography Styles for Markdown Content */
        .prose h2 {
            font-family: 'Newsreader', serif;
            font-size: 2rem;
            font-weight: 500;
            color: #18181b;
            margin-top: 3rem;
            margin-bottom: 1.5rem;
        }
        .prose h3 {
            font-family: 'Newsreader', serif;
            font-size: 1.5rem;
            font-weight: 500;
            color: #27272a;
            margin-top: 2rem;
            margin-bottom: 1rem;
        }
        .prose p {
            color: #52525b;
            line-height: 1.8;
            font-weight: 300;
            font-size: 1.125rem;
            margin-bottom: 1.5rem;
        }
        .prose strong {
            font-weight: 600;
            color: #18181b;
        }
        .prose ul, .prose ol {
            color: #52525b;
            line-height: 1.8;
            font-weight: 300;
            font-size: 1.125rem;
            margin-bottom: 1.5rem;
            padding-left: 1.5rem;
        }
        .prose li {
            margin-bottom: 0.5rem;
            list-style-type: decimal;
        }
        .prose blockquote {
            border-left: 4px solid #3b82f6;
            background: rgba(59, 130, 246, 0.05);
            padding: 1.5rem;
            margin: 2rem 0;
            border-radius: 0 0.75rem 0.75rem 0;
            font-family: 'Newsreader', serif;
            font-style: italic;
            font-size: 1.25rem;
            color: #3f3f46;
        }
        .prose blockquote p {
            margin-bottom: 0;
            color: inherit;
        }
    </style>
</head>
<body class="text-zinc-800 antialiased selection:bg-zinc-200 selection:text-zinc-900 min-h-screen relative">

    <div class="bg-glow"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300">
        <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/" class="font-serif text-xl italic font-medium tracking-tight text-zinc-900 flex items-center group">
                <i data-lucide="arrow-left" class="w-4 h-4 mr-2 text-zinc-400 group-hover:text-zinc-900 transition-colors group-hover:-translate-x-1"></i>
                Milad.
            </a>
            <div class="hidden md:flex items-center space-x-2 text-sm font-medium text-zinc-500">
                <a href="/" class="hover:text-zinc-900 transition-colors">Home</a>
                <span class="text-zinc-300">/</span>
                <span class="text-zinc-900">Blog</span>
            </div>
        </div>
    </nav>

    <main class="max-w-3xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
        <article>
            <header class="mb-16">
                <div class="flex items-center space-x-4 mb-6">
                    <span class="text-sm font-semibold text-zinc-500 tracking-wider">{frontmatter.date}</span>
                    <span class="w-1.5 h-1.5 rounded-full bg-zinc-300"></span>
                    <span class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 rounded-lg text-xs font-bold tracking-wider uppercase shadow-sm">
                        {frontmatter.category}
                    </span>
                </div>
                
                <h1 class="text-4xl sm:text-5xl font-serif text-zinc-900 leading-tight mb-8">
                    {frontmatter.title}
                </h1>
                
                <p class="text-xl md:text-2xl text-zinc-500 font-light leading-relaxed border-l-2 border-emerald-500 pl-6 py-2">
                    {frontmatter.description}
                </p>
            </header>

            <div class="prose max-w-none">
                <slot />
            </div>

            <footer class="mt-20 pt-10 border-t border-zinc-200">
                <div class="flex flex-col sm:flex-row justify-between items-center bg-white p-8 rounded-2xl border border-zinc-200 shadow-sm">
                    <div class="flex items-center mb-6 sm:mb-0">
                        <div class="w-12 h-12 rounded-full overflow-hidden mr-4">
                            <!-- Placeholder avatar -->
                            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=150" alt="Milad" class="w-full h-full object-cover">
                        </div>
                        <div>
                            <p class="font-medium text-zinc-900">Written by Milad</p>
                            <p class="text-sm text-zinc-500">PhD Researcher @ WPI</p>
                        </div>
                    </div>
                    <a href="https://twitter.com/intent/tweet?text={frontmatter.title}" target="_blank" class="inline-flex items-center px-4 py-2 border border-zinc-200 rounded-lg text-sm font-medium text-zinc-700 hover:bg-zinc-50 transition-colors">
                        <i data-lucide="twitter" class="w-4 h-4 mr-2"></i> Share on Twitter
                    </a>
                </div>
            </footer>
        </article>
    </main>

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
