---
import '../../styles/global.css';
import { ArrowLeft, Sun, Moon, Twitter } from 'lucide-astro';
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog | Milad Natanzi</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content="Read my latest articles and tips on AI, Telecom, and Engineering.">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Newsreader', serif; }
        .font-montserrat { font-family: 'Montserrat', sans-serif; }
        
        .glass-nav {
            background: rgba(250, 250, 250, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        }
        
        .dark .glass-nav {
            background: rgba(9, 9, 11, 0.7);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, rgba(250, 250, 250, 0) 70%);
        }
    </style>
    
    <!-- Initialize Theme Script -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300">

    <div class="bg-glow"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300">
        <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/" class="font-sans text-[1.25rem] font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-zinc-900 to-zinc-500 dark:from-zinc-100 dark:to-zinc-400 hover:opacity-80 transition-opacity flex items-center group">
                <ArrowLeft class="w-4 h-4 mr-2 text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors group-hover:-translate-x-1" />
                Milad Natanzi
            </a>
            <div class="flex items-center space-x-4">
                <div class="hidden md:flex items-center space-x-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 mr-2">
                    <a href="/" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Home</a>
                    <span class="text-zinc-300 dark:text-zinc-700">/</span>
                    <span class="text-zinc-900 dark:text-zinc-100">Blog</span>
                </div>
                <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800">
                    <Sun class="hidden dark:block w-4 h-4" />
                    <Moon class="block dark:hidden w-4 h-4" />
                </button>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32 text-center">
        
        {/* Top Yellow Badge */}
        <div class="inline-block px-3 py-1 mb-6 bg-yellow-200/80 dark:bg-yellow-500/20 text-yellow-800 dark:text-yellow-500 text-xs font-bold uppercase tracking-wider rounded-md">
            Blogs & Articles
        </div>

        {/* Main Title & Subtitle */}
        <h1 class="text-4xl md:text-5xl font-extrabold text-zinc-900 dark:text-zinc-100 mb-4 font-montserrat tracking-tight">
            Blogs & Articles
        </h1>
        <p class="text-zinc-500 dark:text-zinc-400 mb-10 max-w-lg mx-auto text-[15px]">
            Subscribe to learn more about my latest research and get the newest tips on AI and Telecom.
        </p>

        {/* Subscribe Form */}
        <form 
            name="subscribe" 
            method="POST" 
            data-netlify="true" 
            netlify-honeypot="bot-field"
            id="subscribe-form"
            class="max-w-md mx-auto mb-20 relative px-4 sm:px-0"
        >
            <input type="hidden" name="form-name" value="subscribe" />
            <p class="hidden">
                <input name="bot-field" />
            </p>
            <input 
                type="email" 
                name="email"
                placeholder="Enter your email address" 
                required
                class="w-full pl-6 pr-32 py-4 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900/50 text-zinc-900 dark:text-zinc-100 shadow-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder-zinc-400" 
            />
            <button type="submit" class="absolute top-2 right-2 sm:right-2 bottom-2 px-6 font-montserrat font-medium text-[13px] text-white bg-blue-500 hover:bg-blue-600 rounded-full transition-colors shadow-sm">
                Subscribe
            </button>
            <div id="subscribe-success" class="hidden absolute -bottom-8 left-0 right-0 text-sm font-medium text-emerald-600 dark:text-emerald-400 animate-fade-up">
                Thanks for subscribing!
            </div>
        </form>

        {/* Category Filters */}
        <div class="flex flex-wrap justify-center gap-6 sm:gap-8 mb-12 text-[15px] font-medium font-inter">
            <button class="text-blue-500 font-semibold">All Article</button>
            <button class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Research</button>
            <button class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Engineering</button>
            <button class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Telecom</button>
            <button class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">AI & ML</button>
        </div>

        {/* Blog Cards Grid */}
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 text-left border-t border-zinc-100 dark:border-zinc-800/60 pt-10">
            
            {/* Card 1 */}
            <a href="/blog/future-of-6g" class="group flex flex-col bg-white dark:bg-zinc-900/40 rounded-2xl overflow-hidden hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgb(0,0,0,0.2)] transition-shadow border border-zinc-100 dark:border-zinc-800/80">
                <div class="aspect-[4/3] overflow-hidden bg-zinc-100 dark:bg-zinc-800">
                    <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&q=80&w=800&h=600" alt="Future of 6G" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-5 md:p-6 flex flex-col flex-grow">
                    <h2 class="text-lg font-bold font-montserrat text-zinc-900 dark:text-zinc-100 mb-3 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                        The Future of 6G: Beyond Speed and Bandwidth
                    </h2>
                    <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed line-clamp-2 mt-auto">
                        Exploring how physical-layer machine learning and continuous adaptation will fundamentally restructure network deployments.
                    </p>
                </div>
            </a>

            {/* Card 2 */}
            <a href="/blog/academia-to-telecom" class="group flex flex-col bg-white dark:bg-zinc-900/40 rounded-2xl overflow-hidden hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgb(0,0,0,0.2)] transition-shadow border border-zinc-100 dark:border-zinc-800/80">
                <div class="aspect-[4/3] overflow-hidden bg-zinc-100 dark:bg-zinc-800">
                    <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&q=80&w=800&h=600" alt="Transition to Telecom" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-5 md:p-6 flex flex-col flex-grow">
                    <h2 class="text-lg font-bold font-montserrat text-zinc-900 dark:text-zinc-100 mb-3 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                        Transitioning from Academia to Telecom Enterprise Systems
                    </h2>
                    <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed line-clamp-2 mt-auto">
                        Lessons learned working with massive-scale data architectures at MTN Group and transitioning back to PhD research.
                    </p>
                </div>
            </a>

            {/* Card 3 (Placeholder) */}
            <a href="#" class="group flex flex-col bg-white dark:bg-zinc-900/40 rounded-2xl overflow-hidden hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgb(0,0,0,0.2)] transition-shadow border border-zinc-100 dark:border-zinc-800/80">
                <div class="aspect-[4/3] overflow-hidden bg-zinc-100 dark:bg-zinc-800 relative">
                    <img src="https://images.unsplash.com/photo-1555949963-aa79dcee981c?auto=format&fit=crop&q=80&w=800&h=600" alt="AI in Networks" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-5 md:p-6 flex flex-col flex-grow">
                    <h2 class="text-lg font-bold font-montserrat text-zinc-900 dark:text-zinc-100 mb-3 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                        Dynamic Spectrum Slicing in 6G Networks using AI
                    </h2>
                    <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed line-clamp-2 mt-auto">
                        An overview of how Multi-Agent Deep Reinforcement Learning can optimize spectrum allocation.
                    </p>
                </div>
            </a>

        </div>
    </main>

    <footer class="mt-20 pt-10 pb-12 border-t border-zinc-200 dark:border-zinc-800 max-w-5xl mx-auto px-6">
        <div class="text-center text-sm text-zinc-500 dark:text-zinc-400 font-medium tracking-wide">
            © 2026 Milad Natanzi. All rights reserved.
        </div>
    </footer>

    <!-- Scripts -->
    <script>
        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('theme-toggle');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', function() {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                }
            });
        }

        // Netlify Form Submission Handler (AJAX)
        const subscribeForm = document.getElementById('subscribe-form');
        const successMessage = document.getElementById('subscribe-success');

        if (subscribeForm) {
            subscribeForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const formData = new FormData(subscribeForm);
                fetch('/', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams(formData).toString()
                })
                .then(() => {
                    successMessage.classList.remove('hidden');
                    subscribeForm.reset();
                    setTimeout(() => {
                        successMessage.classList.add('hidden');
                    }, 5000); // Hide after 5 seconds
                })
                .catch((error) => console.error(error));
            });
        }
    </script>
</body>
</html>
