---
import galleryData from "../../data/gallery.json";
import "../../styles/global.css";
import { Sun, Moon, Menu, X, ArrowLeft } from "lucide-astro";

export async function getStaticPaths() {
    return galleryData.cities.map((city) => ({
        params: { city: city.slug },
        props: { city },
    }));
}

const { city } = Astro.props;
---

<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{city.name} — Out of Office | Milad Natanzi</title>
        <meta
            name="description"
            content={`Photos from ${city.name} by Milad Natanzi. ${city.tagline}`}
        />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap"
            rel="stylesheet"
        />

        <!-- Initialize Theme Script -->
        <script is:inline>
            if (
                localStorage.getItem("theme") === "dark" ||
                (!("theme" in localStorage) &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches)
            ) {
                document.documentElement.classList.add("dark");
            } else {
                document.documentElement.classList.remove("dark");
            }
        </script>

        <style>
            body {
                font-family: "Inter", sans-serif;
            }
            .font-serif {
                font-family: "Newsreader", serif;
            }

            .glass-nav {
                background: rgba(250, 250, 250, 0.85);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border-bottom: 1px solid rgba(0, 0, 0, 0.04);
            }
            .dark .glass-nav {
                background: rgba(9, 9, 11, 0.85);
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }

            /* Masonry layout */
            .masonry {
                columns: 1;
                column-gap: 1rem;
            }
            @media (min-width: 640px) {
                .masonry {
                    columns: 2;
                }
            }
            @media (min-width: 1024px) {
                .masonry {
                    columns: 3;
                }
            }

            .masonry-item {
                break-inside: avoid;
                margin-bottom: 1rem;
                position: relative;
            }

            .masonry-item .photo-wrap {
                position: relative;
                border-radius: 0.75rem;
                overflow: hidden;
                cursor: pointer;
            }

            .masonry-item img {
                display: block;
                width: 100%;
                border-radius: 0.75rem;
                transition: transform 0.4s ease, opacity 0.3s ease,
                    box-shadow 0.3s ease;
            }
            .masonry-item .photo-wrap:hover img {
                transform: scale(1.02);
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
            }

            /* Location label overlay */
            .photo-location {
                position: absolute;
                bottom: 0.6rem;
                left: 0.75rem;
                font-size: 0.65rem;
                letter-spacing: 0.08em;
                color: rgba(255, 255, 255, 0.75);
                font-family: "Inter", sans-serif;
                text-transform: uppercase;
                opacity: 0;
                transition: opacity 0.3s ease;
                pointer-events: none;
                text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
            }
            .masonry-item .photo-wrap:hover .photo-location {
                opacity: 1;
            }

            /* Lightbox */
            #lightbox {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 1000;
                background: rgba(0, 0, 0, 0.95);
                backdrop-filter: blur(8px);
                align-items: center;
                justify-content: center;
                flex-direction: column;
            }
            #lightbox.open {
                display: flex;
            }

            #lightbox img {
                max-height: 80vh;
                max-width: 90vw;
                object-fit: contain;
                border-radius: 0.75rem;
                box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
                animation: lb-in 0.25s ease;
            }
            @keyframes lb-in {
                from {
                    opacity: 0;
                    transform: scale(0.96);
                }
                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            .lb-btn {
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.12);
                color: white;
                width: 48px;
                height: 48px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: background 0.2s;
                font-size: 1.25rem;
            }
            .lb-btn:hover {
                background: rgba(255, 255, 255, 0.18);
            }
            #lb-prev {
                left: 1.5rem;
            }
            #lb-next {
                right: 1.5rem;
            }
            #lb-close {
                position: absolute;
                top: 1.5rem;
                right: 1.5rem;
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.12);
                color: white;
                width: 40px;
                height: 40px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-size: 1.2rem;
                transition: background 0.2s;
            }
            #lb-close:hover {
                background: rgba(255, 255, 255, 0.18);
            }
            #lb-caption {
                position: absolute;
                bottom: 2.5rem;
                left: 50%;
                transform: translateX(-50%);
                color: rgba(255, 255, 255, 0.7);
                font-size: 0.875rem;
                text-align: center;
                white-space: nowrap;
            }
            #lb-location {
                position: absolute;
                bottom: 1.2rem;
                left: 50%;
                transform: translateX(-50%);
                color: rgba(255, 255, 255, 0.4);
                font-size: 0.65rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                white-space: nowrap;
            }
            #lb-counter {
                position: absolute;
                top: 1.5rem;
                left: 50%;
                transform: translateX(-50%);
                color: rgba(255, 255, 255, 0.5);
                font-size: 0.8rem;
                letter-spacing: 0.1em;
            }
        </style>
    </head>

    <body
        class="bg-zinc-50 dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300"
    >
        <!-- Navigation -->
        <nav
            class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300"
            id="main-nav"
        >
            <div
                class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between"
            >
                <a
                    href="/gallery"
                    class="flex items-center text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors group"
                >
                    <ArrowLeft
                        class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform"
                    /> Back
                </a>

                <div
                    class="hidden md:flex items-center space-x-8 text-[13px] font-montserrat font-normal tracking-[0.5px] text-zinc-500 dark:text-zinc-400 capitalize"
                >
                    <a
                        href="/#about"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >About</a
                    >
                    <a
                        href="/#news"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >News</a
                    >
                    <a
                        href="/cv"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >CV</a
                    >
                    <a
                        href="/#experience"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >Experience</a
                    >
                    <a
                        href="/#projects"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >Projects</a
                    >
                    <a
                        href="/#blog"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >Blog</a
                    >
                    <a
                        href="/gallery"
                        class="nav-link py-1 text-zinc-900 dark:text-white transition-colors font-medium"
                        >Out of office</a
                    >
                </div>

                <div class="flex items-center space-x-4">
                    <button
                        id="theme-toggle"
                        class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800 hidden md:block"
                    >
                        <Sun class="hidden dark:block w-4 h-4" />
                        <Moon class="block dark:hidden w-4 h-4" />
                    </button>
                    <a
                        href="mailto:milad@natanzi.com"
                        class="hidden md:inline-flex items-center justify-center px-5 py-2 text-[13px] font-montserrat font-medium tracking-[0.5px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-colors shadow-sm"
                    >
                        Let's Talk
                    </a>
                </div>

                <!-- Mobile Menu Toggle -->
                <button
                    id="mobile-menu-btn"
                    class="md:hidden text-zinc-500 hover:text-zinc-900 p-2 -mr-2 focus:outline-none"
                >
                    <div id="icon-menu-wrapper"><Menu class="w-6 h-6" /></div>
                    <div id="icon-close-wrapper" class="hidden">
                        <X class="w-6 h-6" />
                    </div>
                </button>
            </div>
        </nav>

        <!-- Mobile Menu Overlay -->
        <div
            id="mobile-menu"
            class="fixed inset-0 bg-white/98 dark:bg-zinc-950/98 backdrop-blur-xl z-[60] hidden flex-col justify-center items-center opacity-0 transition-opacity duration-300"
        >
            <nav class="flex flex-col items-center space-y-7 w-full px-6">
                <a
                    href="/#about"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >About</a
                >
                <a
                    href="/#news"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >News</a
                >
                <a
                    href="/cv"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >CV</a
                >
                <a
                    href="/#experience"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >Experience</a
                >
                <a
                    href="/#projects"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >Projects</a
                >
                <a
                    href="/#blog"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >Blog</a
                >
                <a
                    href="/gallery"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white transition-colors capitalize"
                    >Out of office</a
                >

                <div class="pt-8 w-full max-w-[240px]">
                    <a
                        href="mailto:milad@natanzi.com"
                        class="mobile-link flex items-center justify-center px-6 py-4 text-[15px] font-montserrat font-medium tracking-[1px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full shadow-lg active:scale-95 transition-transform uppercase"
                    >
                        Let's Talk
                    </a>
                </div>
            </nav>
        </div>

        <main class="pt-32 pb-24 max-w-6xl mx-auto px-6">
            <!-- Header -->
            <header class="mb-16">
                <p
                    class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-4"
                >
                    Out of Office / {city.name}
                </p>
                <h1
                    class="text-5xl md:text-7xl font-serif text-zinc-900 dark:text-zinc-50 mb-4"
                >
                    {city.name}
                </h1>
                <p class="text-lg text-zinc-500 dark:text-zinc-400 font-light">
                    {city.tagline}
                </p>
                <div class="mt-6 h-px bg-zinc-200 dark:bg-zinc-800"></div>
            </header>

            <!-- Masonry Photo Grid -->
            <div class="masonry" id="photo-grid">
                {
                    city.photos.map((photo, index) => (
                        <div class="masonry-item" data-index={index}>
                            <div class="photo-wrap">
                                <img
                                    src={photo.src}
                                    alt={photo.caption}
                                    loading={index < 3 ? "eager" : "lazy"}
                                    class="gallery-photo"
                                />
                                {photo.location && (
                                    <span class="photo-location">
                                        📍 {photo.location}
                                    </span>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
        </main>

        <!-- Lightbox -->
        <div
            id="lightbox"
            role="dialog"
            aria-modal="true"
            aria-label="Photo lightbox"
        >
            <button id="lb-close" aria-label="Close lightbox">&#10005;</button>
            <span id="lb-counter"></span>

            <button class="lb-btn" id="lb-prev" aria-label="Previous photo"
                >&#8592;</button
            >
            <img id="lb-img" src="" alt="Gallery photo" />
            <button class="lb-btn" id="lb-next" aria-label="Next photo"
                >&#8594;</button
            >

            <span id="lb-caption"></span>
            <span id="lb-location"></span>
        </div>

        <script define:vars={{ photos: city.photos }}>
            let currentIndex = 0;

            const lightbox = document.getElementById("lightbox");
            const lbImg = document.getElementById("lb-img");
            const lbCaption = document.getElementById("lb-caption");
            const lbCounter = document.getElementById("lb-counter");
            const lbClose = document.getElementById("lb-close");
            const lbPrev = document.getElementById("lb-prev");
            const lbNext = document.getElementById("lb-next");

            function openLightbox(index) {
                currentIndex = index;
                updateLightbox();
                lightbox.classList.add("open");
                document.body.style.overflow = "hidden";
            }

            function closeLightbox() {
                lightbox.classList.remove("open");
                document.body.style.overflow = "";
            }

            function updateLightbox() {
                const photo = photos[currentIndex];
                lbImg.src = photo.src;
                lbImg.alt = photo.caption;
                lbCaption.textContent = photo.caption;
                lbCounter.textContent = `${currentIndex + 1} / ${
                    photos.length
                }`;
                const lbLocation = document.getElementById("lb-location");
                if (lbLocation)
                    lbLocation.textContent = photo.location
                        ? `📍 ${photo.location}`
                        : "";
            }

            function showPrev() {
                currentIndex =
                    (currentIndex - 1 + photos.length) % photos.length;
                updateLightbox();
            }

            function showNext() {
                currentIndex = (currentIndex + 1) % photos.length;
                updateLightbox();
            }

            // Attach click to each photo
            document
                .querySelectorAll(".gallery-photo")
                .forEach((img, index) => {
                    img.addEventListener("click", () => openLightbox(index));
                });

            lbClose.addEventListener("click", closeLightbox);
            lbPrev.addEventListener("click", showPrev);
            lbNext.addEventListener("click", showNext);

            // Click backdrop to close
            lightbox.addEventListener("click", (e) => {
                if (e.target === lightbox) closeLightbox();
            });

            // Keyboard navigation
            document.addEventListener("keydown", (e) => {
                if (!lightbox.classList.contains("open")) return;
                if (e.key === "ArrowRight") showNext();
                if (e.key === "ArrowLeft") showPrev();
                if (e.key === "Escape") closeLightbox();
            });

            // Theme toggle
            document
                .getElementById("theme-toggle")
                .addEventListener("click", () => {
                    if (document.documentElement.classList.contains("dark")) {
                        document.documentElement.classList.remove("dark");
                        localStorage.setItem("theme", "light");
                    } else {
                        document.documentElement.classList.add("dark");
                        localStorage.setItem("theme", "dark");
                    }
                });
        </script>
    </body>
</html>
