---
import galleryData from '../../data/gallery.json';
import '../../styles/global.css';

const cities = galleryData.cities;
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Out of Office — Gallery | Milad Natanzi</title>
    <meta name="description" content="A visual journal of places visited by Milad Natanzi. Stepping away from the servers and lab to capture the world in focus.">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">

    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Newsreader', serif; }

        .glass-nav {
            background: rgba(250,250,250,0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0,0,0,0.04);
        }
        .dark .glass-nav {
            background: rgba(9,9,11,0.85);
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }

        .city-card {
            position: relative;
            overflow: hidden;
            border-radius: 1rem;
            aspect-ratio: 4/5;
            cursor: pointer;
            display: block;
            text-decoration: none;
        }
        .city-card img {
            width: 100%; height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease, filter 0.5s ease;
            filter: grayscale(30%);
        }
        .city-card:hover img {
            transform: scale(1.06);
            filter: grayscale(0%);
        }
        .city-card-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
            transition: opacity 0.4s ease;
        }
        .city-card:hover .city-card-overlay {
            opacity: 0.85;
        }
        .city-card-text {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            padding: 1.5rem;
        }
    </style>
</head>

<body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300">

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/" class="flex items-center text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors group">
                <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Back to Home
            </a>
            <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-700 transition-colors">
                <svg id="icon-sun" class="hidden dark:block w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                <svg id="icon-moon" class="block dark:hidden w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
            </button>
        </div>
    </nav>

    <main class="pt-32 pb-24 max-w-6xl mx-auto px-6">
        <!-- Header -->
        <header class="mb-16">
            <div class="flex items-center gap-3 mb-6">
                <svg class="w-5 h-5 text-zinc-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <span class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500">Out of Office</span>
            </div>

            <p class="text-lg text-zinc-500 dark:text-zinc-400 font-light max-w-xl">
                Stepping away from the servers and lab to capture the world in focus.
            </p>
            <div class="mt-8 h-px bg-zinc-200 dark:bg-zinc-800"></div>
        </header>

        <!-- City Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
            {cities.map((city, i) => (
                <a href={`/gallery/${city.slug}`} class="city-card group">
                    <img 
                        src={city.cover} 
                        alt={city.name}
                        loading={i === 0 ? "eager" : "lazy"} 
                    />
                    <div class="city-card-overlay"></div>
                    <div class="city-card-text">
                        <p class="text-white/60 text-xs font-semibold uppercase tracking-widest mb-1">{city.photos.length} Photos</p>
                        <h2 class="text-2xl font-serif text-white">{city.name}</h2>
                        <p class="text-white/70 text-sm mt-1 font-light">{city.tagline}</p>
                    </div>
                </a>
            ))}
        </div>

        <!-- Footer note -->
        <p class="mt-16 text-center text-sm text-zinc-400 dark:text-zinc-600 font-light italic">
            More cities coming soon...
        </p>
    </main>

    <script>
        document.getElementById('theme-toggle')?.addEventListener('click', () => {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        });
    </script>
</body>
</html>
