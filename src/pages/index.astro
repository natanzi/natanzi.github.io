---
import '../styles/global.css';
import { 
    Menu, X, FileText, BookOpen, ArrowRight, ArrowUpRight, 
    Briefcase, Cpu, Radio, ShieldAlert, Network, Activity,
    PenTool, Camera, Mail, Linkedin, Github, Hammer, Server, Code, Database, Moon, Sun 
} from 'lucide-astro';
import siteSettings from '../data/settings.json';

const pageTitle = "Milad Natanzi | ECE Researcher & Data Scientist";
const siteDescription = "Milad Natanzi is a PhD Candidate in ECE at WPI, blending 7+ years of telecom industry experience from MTN Group with advanced machine intelligence. Specializing in 5G/6G infrastructures and O-RAN.";
const siteUrl = "https://natanzi.com";
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{siteSettings.under_construction ? "Coming Soon | Milad Natanzi" : pageTitle}</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content={siteDescription}>
    <meta name="author" content="Milad Natanzi">
    <link rel="canonical" href={siteUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={siteUrl}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={siteDescription}>
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content={siteUrl}>
    <meta property="twitter:title" content={pageTitle}>
    <meta property="twitter:description" content={siteDescription}>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Milad Natanzi",
      "jobTitle": "PhD Candidate, ECE Researcher & Data Scientist",
      "url": "https://natanzi.com",
      "sameAs": [
        "https://www.linkedin.com/in/miladnatanzi",
        "https://github.com/natanzi"
      ]
    })} />

    <!-- Google Fonts: Inter & Newsreader -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    
    <!-- Netlify Identity Widget -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
        body { 
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
        }
        .font-serif {
            font-family: 'Newsreader', serif;
        }
        
        /* Refined animations */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up {
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 150ms; }
        .delay-200 { animation-delay: 300ms; }
        .delay-300 { animation-delay: 450ms; }
        
        /* Glass styling */
        .glass-nav {
            background: rgba(250, 250, 250, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        }
        
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
        }
        
        .dark .glass-card {
            background: rgba(24, 24, 27, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2), 0 2px 4px -1px rgba(0, 0, 0, 0.1);
        }

        .glass-card-hover {
            transition: all 0.3s ease;
        }
        .glass-card-hover:hover {
            background: rgba(255, 255, 255, 1);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.025);
            border-color: rgba(0,0,0,0.08);
        }
        
        /* Subtle background glow effect */
        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, rgba(250, 250, 250, 0) 70%);
        }
        .bg-glow::after {
            content: '';
            position: absolute;
            bottom: -10%; left: -5%;
            width: 60vw; height: 60vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.03) 0%, rgba(250, 250, 250, 0) 70%);
        }

        /* Image Masking for Hero */
        .hero-image-mask {
            mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
        }

        /* Gradient Text */
        .text-gradient-light {
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-image: linear-gradient(135deg, #3b82f6 0%, #10b981 100%);
        }
        
        /* Mobile menu open state */
        .mobile-menu-active {
            display: flex !important;
        }
        .no-scroll {
            overflow: hidden;
        }
        
        /* Dark Mode bg glow */
        .dark .bg-glow::before { background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, rgba(9, 9, 11, 0) 70%); }
        .dark .bg-glow::after { background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, rgba(9, 9, 11, 0) 70%); }
        .dark .glass-nav {
            background: rgba(9, 9, 11, 0.7);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }
    </style>
    
    <!-- Initialize Theme Script -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class={siteSettings.under_construction ? "antialiased flex items-center justify-center min-h-screen relative overflow-hidden bg-zinc-50 dark:bg-zinc-950 transition-colors duration-300" : "text-zinc-800 dark:text-zinc-300 antialiased selection:bg-zinc-200 dark:selection:bg-zinc-800 selection:text-zinc-900 dark:selection:text-white min-h-screen relative bg-[#fafafa] dark:bg-zinc-950 transition-colors duration-300"}>

{siteSettings.under_construction ? (
    <Fragment>
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-100 to-zinc-200 z-0"></div>
        <div class="relative z-10 text-center px-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white dark:bg-zinc-900 shadow-xl mb-8 border border-transparent dark:border-zinc-800">
                <Hammer class="w-8 h-8 text-zinc-900 dark:text-zinc-100" />
            </div>
            <h1 class="text-5xl md:text-6xl font-serif text-zinc-900 dark:text-white mb-6">Under Construction</h1>
            <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-md mx-auto">I'm currently updating my portfolio. Please check back shortly.</p>
        </div>
    </Fragment>
) : (
    <Fragment>
    <div class="bg-glow"></div>

    <!-- Sticky Navigation Bar -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300" id="main-nav">
        <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="#" class="font-serif text-xl italic font-medium tracking-tight text-zinc-900">Milad Natanzi</a>
            
            <div class="hidden md:flex items-center space-x-8 text-sm font-medium text-zinc-500 dark:text-zinc-400">
                <a href="#about" class="hover:text-zinc-900 dark:hover:text-white transition-colors">About</a>
                <a href="#experience" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Experience</a>
                <a href="#projects" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Projects</a>
                <a href="#blog" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Blog</a>
                <a href="#photography" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Photography</a>
            </div>
            
            <div class="flex items-center space-x-4">
                <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800 hidden md:block">
                    <Sun class="hidden dark:block w-4 h-4" />
                    <Moon class="block dark:hidden w-4 h-4" />
                </button>
                <a href="#contact" class="hidden md:inline-flex items-center justify-center px-5 py-2 text-xs font-semibold tracking-wide text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-colors shadow-sm">
                    Get in touch
                </a>
            </div>
            
            <!-- Mobile Menu Toggle -->
            <button id="mobile-menu-btn" class="md:hidden text-zinc-500 hover:text-zinc-900 p-2 -mr-2 focus:outline-none">
                <div id="icon-menu-wrapper"><Menu class="w-6 h-6" /></div>
                <div id="icon-close-wrapper" class="hidden"><X class="w-6 h-6" /></div>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-white/95 backdrop-blur-md z-40 hidden flex-col justify-center items-center space-y-8 opacity-0 transition-opacity duration-300 pt-16">
        <a href="#about" class="mobile-link text-2xl font-serif text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">About</a>
        <a href="#experience" class="mobile-link text-2xl font-serif text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">Experience</a>
        <a href="#projects" class="mobile-link text-2xl font-serif text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">Projects</a>
        <a href="#blog" class="mobile-link text-2xl font-serif text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">Blog</a>
        <a href="#photography" class="mobile-link text-2xl font-serif text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">Photography</a>
        <a href="#contact" class="mobile-link mt-8 px-8 py-3 text-sm font-medium tracking-wide text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full shadow-md">
            Get in touch
        </a>
    </div>

    <main class="max-w-5xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
        
        <!-- Hero Section with Image Split -->
        <header id="about" class="mb-32 animate-fade-up">
            <div class="flex flex-col-reverse lg:flex-row gap-12 lg:gap-16 items-center lg:items-center">
                
                <!-- Text Content -->
                <div class="flex-1 w-full">
                    <div class="inline-flex items-center space-x-2 px-3 py-1.5 rounded-full bg-white border border-zinc-200 shadow-sm mb-8">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        <span class="text-[11px] font-semibold text-zinc-600 uppercase tracking-widest pl-1">I am in job market now</span>
                    </div>
                    

                    
                    <div class="text-base md:text-lg text-zinc-600 dark:text-zinc-400 font-light leading-relaxed mb-8 max-w-2xl space-y-4">
                        <p>
                            Hello! I am Milad, a Ph.D. Candidate and researcher in the Department of Electrical and Computer Engineering at <strong class="text-zinc-800 dark:text-zinc-200 font-medium">Worcester Polytechnic Institute (WPI)</strong>.
                        </p>
                        <p>
                            My research bridges the gap between advanced artificial intelligence and next-generation telecommunications. Specifically, my interests focus on:
                        </p>
                        <ul class="list-disc pl-5 space-y-1">
                            <li>5G and 6G wireless infrastructure and O-RAN architecture.</li>
                            <li>Beamforming optimization and spectrum management.</li>
                            <li>Integrating Machine Learning (Continual & Reinforcement Learning) into physical-layer systems.</li>
                            <li>Building and managing high-performance GPU clusters and software-defined radio (SDR) environments.</li>
                        </ul>
                        <p>
                            Prior to my academic career, I spent over seven years as a Data Scientist and Engineer in the telecommunications industry, working with global enterprise systems including the MTN Group. I am currently completing my Ph.D. under the supervision of Dr. Bo Tang.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-2 mb-10 max-w-2xl">
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">5G/6G Networks</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">Machine Learning</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">Python</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">O-RAN</span>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 max-w-md">
                        <a href="#" class="group flex items-center justify-between px-5 py-4 glass-card glass-card-hover rounded-xl w-full">
                            <div class="flex items-center text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                                <span class="bg-blue-50 dark:bg-blue-900/30 p-2 rounded-lg mr-3 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/50 transition-colors">
                                    <FileText class="w-4 h-4 text-blue-600 dark:text-blue-400" />
                                </span>
                                Read My CV
                            </div>
                            <ArrowRight class="w-4 h-4 text-zinc-400 dark:text-zinc-500 group-hover:text-zinc-800 dark:group-hover:text-zinc-300 group-hover:translate-x-1 transition-all" />
                        </a>
                        <a href="#" class="group flex items-center justify-between px-5 py-4 glass-card glass-card-hover rounded-xl w-full">
                            <div class="flex items-center text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                                <span class="bg-emerald-50 dark:bg-emerald-900/30 p-2 rounded-lg mr-3 group-hover:bg-emerald-100 dark:group-hover:bg-emerald-900/50 transition-colors">
                                    <BookOpen class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />
                                </span>
                                Publications
                            </div>
                            <ArrowRight class="w-4 h-4 text-zinc-400 dark:text-zinc-500 group-hover:text-zinc-800 dark:group-hover:text-zinc-300 group-hover:translate-x-1 transition-all" />
                        </a>
                    </div>
                </div>

                <!-- Image Profile (Hero) -->
                <div class="w-full lg:w-5/12 max-w-md mx-auto lg:mx-0 relative lg:pl-8">
                    <div class="absolute -inset-4 bg-gradient-to-tr from-blue-100 via-emerald-50 to-transparent rounded-3xl blur-2xl opacity-50 z-0"></div>
                    <div class="relative z-10 aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl shadow-zinc-200/50 border border-white bg-white">
                        <!-- Placeholder Image (Replace with user's actual photo) -->
                        <img src="/Milad-Natanzi.jpg" 
                             alt="Milad" 
                             class="w-full h-full object-cover object-center hero-image-mask hover:scale-105 transition-transform duration-1000 ease-out" />
                    </div>
                </div>

            </div>
        </header>

        <!-- Experience Section -->
        <section id="experience" class="mb-32 animate-fade-up delay-100 scroll-mt-24">
            <div class="flex items-center mb-12">
                <h2 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest flex items-center gap-2">
                    <Briefcase class="w-4 h-4 text-blue-500" /> Experience
                </h2>
                <div class="ml-6 h-px bg-zinc-200 flex-grow"></div>
            </div>
            
            <div class="space-y-12 pl-4 md:pl-0">
                <!-- Role 1 -->
                <div class="relative pl-8 md:pl-0 md:grid md:grid-cols-4 md:items-baseline md:gap-8">
                    <div class="absolute left-0 top-2 bottom-0 w-px bg-blue-200 dark:bg-blue-900/50 md:hidden"></div>
                    <div class="absolute left-[-5px] top-2 w-2.5 h-2.5 rounded-full bg-blue-500 dark:bg-blue-400 md:hidden border-2 border-[#fafafa] dark:border-zinc-950 shadow-sm"></div>
                    
                    <div class="md:col-span-1 border-t-2 border-blue-500 dark:border-blue-400 w-12 mb-4 hidden md:block relative">
                        <div class="absolute right-[-4px] top-[-5px] w-2 h-2 rounded-full bg-blue-500 dark:bg-blue-400"></div>
                    </div>
                    <div class="md:col-span-3 pb-10 border-b border-zinc-100/80 dark:border-zinc-800/80 last:border-0 last:pb-0">
                        <div class="flex flex-col md:flex-row md:justify-between md:items-baseline mb-2">
                            <h3 class="text-xl md:text-2xl font-semibold text-zinc-900 dark:text-zinc-100">PhD Researcher</h3>
                            <span class="inline-block py-1 px-3 rounded-full bg-zinc-100 dark:bg-zinc-800 text-xs text-zinc-600 dark:text-zinc-400 font-semibold tabular-nums mt-2 md:mt-0 w-max">2023 — Present</span>
                        </div>
                        <div class="text-sm md:text-base text-blue-600 dark:text-blue-400 mb-4 font-serif italic">Worcester Polytechnic Institute (WPI)</div>
                        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-light text-base md:text-lg">
                            Spearheading research on 5G/6G wireless infrastructure, efficient spectrum management, and optimizing O-RAN architecture. Developing novel approaches by integrating Machine Learning techniques—such as Continual and Reinforcement Learning—into physical-layer communications tasks to achieve higher network autonomy.
                        </p>
                    </div>
                </div>
                
                <!-- Role 2 -->
                <div class="relative pl-8 md:pl-0 md:grid md:grid-cols-4 md:items-baseline md:gap-8">
                    <div class="absolute left-0 top-2 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800 md:hidden"></div>
                    <div class="absolute left-[-4px] top-2 w-2 h-2 rounded-full bg-zinc-400 dark:bg-zinc-600 md:hidden border-2 border-[#fafafa] dark:border-zinc-950"></div>
                    
                    <div class="md:col-span-1 border-t-2 border-zinc-300 dark:border-zinc-700 w-12 mb-4 hidden md:block relative">
                        <div class="absolute right-[-3px] top-[-4px] w-1.5 h-1.5 rounded-full bg-zinc-400 dark:bg-zinc-600"></div>
                    </div>
                    <div class="md:col-span-3 pb-4">
                        <div class="flex flex-col md:flex-row md:justify-between md:items-baseline mb-2">
                            <h3 class="text-xl md:text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Data Scientist & Engineer</h3>
                            <span class="inline-block py-1 px-3 rounded-full bg-zinc-100 dark:bg-zinc-800 text-xs text-zinc-600 dark:text-zinc-400 font-semibold tabular-nums mt-2 md:mt-0 w-max">2014 — 2021</span>
                        </div>
                        <div class="text-sm md:text-base text-zinc-500 dark:text-zinc-400 mb-4 font-serif italic">MTN Group</div>
                        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-light text-base md:text-lg">
                            Spent seven years driving impact in the telecommunications industry, specializing in large-scale data engineering. Built and maintained critical data infrastructure, developed predictive models, and implemented network optimization algorithms for global enterprise systems handling massive daily throughput.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Skills & Tools Section -->
        <section id="skills" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
            <div class="flex items-center mb-12">
                <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
                    <Code class="w-4 h-4 text-orange-500" /> Skills & Tools
                </h2>
                <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
            </div>
            
            <div class="flex flex-wrap gap-4">
                <div class="flex items-center px-4 py-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                    <Server class="w-5 h-5 text-zinc-500 dark:text-zinc-400 mr-3" />
                    <span class="font-medium text-zinc-800 dark:text-zinc-200">Sionna & USRP</span>
                </div>
                <div class="flex items-center px-4 py-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                    <Activity class="w-5 h-5 text-zinc-500 dark:text-zinc-400 mr-3" />
                    <span class="font-medium text-zinc-800 dark:text-zinc-200">PyTorch</span>
                </div>
                <div class="flex items-center px-4 py-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                    <Code class="w-5 h-5 text-zinc-500 dark:text-zinc-400 mr-3" />
                    <span class="font-medium text-zinc-800 dark:text-zinc-200">Python & MATLAB</span>
                </div>
                <div class="flex items-center px-4 py-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                    <Network class="w-5 h-5 text-zinc-500 dark:text-zinc-400 mr-3" />
                    <span class="font-medium text-zinc-800 dark:text-zinc-200">O-RAN</span>
                </div>
                <div class="flex items-center px-4 py-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                    <Database class="w-5 h-5 text-zinc-500 dark:text-zinc-400 mr-3" />
                    <span class="font-medium text-zinc-800 dark:text-zinc-200">Docker & Kubernetes</span>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section id="projects" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
            <div class="flex items-center mb-12">
                <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest flex items-center gap-2">
                    <Cpu class="w-4 h-4 text-emerald-500" /> Selected Works
                </h2>
                <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Project 1 -->
                <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
