---
import '../styles/global.css';

const pageTitle = "Milad | ECE Researcher & Data Scientist";
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{pageTitle}</title>
    <!-- Google Fonts: Inter & Newsreader -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Netlify Identity Widget -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
        body { 
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
        }
        .font-serif {
            font-family: 'Newsreader', serif;
        }
        
        /* Refined animations */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up {
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 150ms; }
        .delay-200 { animation-delay: 300ms; }
        .delay-300 { animation-delay: 450ms; }
        
        /* Glass styling */
        .glass-nav {
            background: rgba(250, 250, 250, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        }
        
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
        }

        .glass-card-hover {
            transition: all 0.3s ease;
        }
        .glass-card-hover:hover {
            background: rgba(255, 255, 255, 1);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.025);
            border-color: rgba(0,0,0,0.08);
        }
        
        /* Subtle background glow effect */
        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, rgba(250, 250, 250, 0) 70%);
        }
        .bg-glow::after {
            content: '';
            position: absolute;
            bottom: -10%; left: -5%;
            width: 60vw; height: 60vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.03) 0%, rgba(250, 250, 250, 0) 70%);
        }

        /* Image Masking for Hero */
        .hero-image-mask {
            mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
        }

        /* Gradient Text */
        .text-gradient-light {
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-image: linear-gradient(135deg, #3b82f6 0%, #10b981 100%);
        }
        
        /* Mobile menu open state */
        .mobile-menu-active {
            display: flex !important;
        }
        .no-scroll {
            overflow: hidden;
        }
    </style>
</head>
<body class="text-zinc-800 antialiased selection:bg-zinc-200 selection:text-zinc-900 min-h-screen relative">

    <div class="bg-glow"></div>

    <!-- Sticky Navigation Bar -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300" id="main-nav">
        <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="#" class="font-serif text-xl italic font-medium tracking-tight text-zinc-900">Milad.</a>
            
            <div class="hidden md:flex items-center space-x-8 text-sm font-medium text-zinc-500">
                <a href="#about" class="hover:text-zinc-900 transition-colors">About</a>
                <a href="#experience" class="hover:text-zinc-900 transition-colors">Experience</a>
                <a href="#projects" class="hover:text-zinc-900 transition-colors">Projects</a>
                <a href="#blog" class="hover:text-zinc-900 transition-colors">Blog</a>
                <a href="#photography" class="hover:text-zinc-900 transition-colors">Photography</a>
            </div>
            
            <a href="#contact" class="hidden md:inline-flex items-center justify-center px-5 py-2 text-xs font-semibold tracking-wide text-white bg-zinc-900 rounded-full hover:bg-zinc-800 transition-colors shadow-sm">
                Get in touch
            </a>
            
            <!-- Mobile Menu Toggle -->
            <button id="mobile-menu-btn" class="md:hidden text-zinc-500 hover:text-zinc-900 p-2 -mr-2 focus:outline-none">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-white/95 backdrop-blur-md z-40 hidden flex-col justify-center items-center space-y-8 opacity-0 transition-opacity duration-300 pt-16">
        <a href="#about" class="mobile-link text-2xl font-serif text-zinc-600 hover:text-zinc-900 transition-colors">About</a>
        <a href="#experience" class="mobile-link text-2xl font-serif text-zinc-600 hover:text-zinc-900 transition-colors">Experience</a>
        <a href="#projects" class="mobile-link text-2xl font-serif text-zinc-600 hover:text-zinc-900 transition-colors">Projects</a>
        <a href="#blog" class="mobile-link text-2xl font-serif text-zinc-600 hover:text-zinc-900 transition-colors">Blog</a>
        <a href="#photography" class="mobile-link text-2xl font-serif text-zinc-600 hover:text-zinc-900 transition-colors">Photography</a>
        <a href="#contact" class="mobile-link mt-8 px-8 py-3 text-sm font-medium tracking-wide text-white bg-zinc-900 rounded-full shadow-md">
            Get in touch
        </a>
    </div>

    <main class="max-w-5xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
        
        <!-- Hero Section with Image Split -->
        <header id="about" class="mb-32 animate-fade-up">
            <div class="flex flex-col-reverse lg:flex-row gap-12 lg:gap-16 items-center lg:items-center">
                
                <!-- Text Content -->
                <div class="flex-1 w-full">
                    <div class="inline-flex items-center space-x-2 px-3 py-1.5 rounded-full bg-white border border-zinc-200 shadow-sm mb-8">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        <span class="text-[11px] font-semibold text-zinc-600 uppercase tracking-widest pl-1">Open to Research Roles</span>
                    </div>
                    
                    <h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight text-zinc-900 mb-6 font-serif leading-[1.1] max-w-2xl lg:max-w-none">
                        Designing the future of <br class="hidden sm:block" />
                        <span class="italic text-gradient-light font-medium">telecommunications.</span>
                    </h1>
                    
                    <p class="text-lg md:text-xl text-zinc-600 font-light leading-relaxed mb-8 max-w-2xl">
                        I am a PhD Candidate in ECE at WPI, blending <strong class="text-zinc-800 font-medium">7+ years of telecom industry experience</strong> from MTN Group with advanced machine intelligence. Specializing in 5G/6G infrastructures and O-RAN.
                    </p>

                    <div class="flex flex-wrap gap-2 mb-10 max-w-2xl">
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 bg-white border border-zinc-200 rounded-lg shadow-sm">5G/6G Networks</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 bg-white border border-zinc-200 rounded-lg shadow-sm">Machine Learning</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 bg-white border border-zinc-200 rounded-lg shadow-sm">Python</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 bg-white border border-zinc-200 rounded-lg shadow-sm">O-RAN</span>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 max-w-md">
                        <a href="#" class="group flex items-center justify-between px-5 py-4 glass-card glass-card-hover rounded-xl w-full">
                            <div class="flex items-center text-sm font-semibold text-zinc-800">
                                <span class="bg-blue-50 p-2 rounded-lg mr-3 group-hover:bg-blue-100 transition-colors">
                                    <i data-lucide="file-text" class="w-4 h-4 text-blue-600"></i>
                                </span>
                                Read My CV
                            </div>
                            <i data-lucide="arrow-right" class="w-4 h-4 text-zinc-400 group-hover:text-zinc-800 group-hover:translate-x-1 transition-all"></i>
                        </a>
                        <a href="#" class="group flex items-center justify-between px-5 py-4 glass-card glass-card-hover rounded-xl w-full">
                            <div class="flex items-center text-sm font-semibold text-zinc-800">
                                <span class="bg-emerald-50 p-2 rounded-lg mr-3 group-hover:bg-emerald-100 transition-colors">
                                    <i data-lucide="book-open" class="w-4 h-4 text-emerald-600"></i>
                                </span>
                                Publications
                            </div>
                            <i data-lucide="arrow-right" class="w-4 h-4 text-zinc-400 group-hover:text-zinc-800 group-hover:translate-x-1 transition-all"></i>
                        </a>
                    </div>
                </div>

                <!-- Image Profile (Hero) -->
                <div class="w-full lg:w-5/12 max-w-md mx-auto lg:mx-0 relative lg:pl-8">
                    <div class="absolute -inset-4 bg-gradient-to-tr from-blue-100 via-emerald-50 to-transparent rounded-3xl blur-2xl opacity-50 z-0"></div>
                    <div class="relative z-10 aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl shadow-zinc-200/50 border border-white bg-white">
                        <!-- Placeholder Image (Replace with user's actual photo) -->
                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=800" 
                             alt="Milad" 
                             class="w-full h-full object-cover object-center hero-image-mask hover:scale-105 transition-transform duration-1000 ease-out" />
                        
                        <div class="absolute bottom-6 left-6 right-6 p-4 glass-card rounded-xl backdrop-blur-md">
                            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1">Current Focus</p>
                            <p class="text-sm font-medium text-zinc-900 leading-tight">Optimizing 6G Beamforming via Local Context Memory AI.</p>
                        </div>
                    </div>
                </div>

            </div>
        </header>

        <!-- Experience Section -->
        <section id="experience" class="mb-32 animate-fade-up delay-100 scroll-mt-24">
            <div class="flex items-center mb-12">
                <h2 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="briefcase" class="w-4 h-4 text-blue-500"></i> Experience
                </h2>
                <div class="ml-6 h-px bg-zinc-200 flex-grow"></div>
            </div>
            
            <div class="space-y-12 pl-4 md:pl-0">
                <!-- Role 1 -->
                <div class="relative pl-8 md:pl-0 md:grid md:grid-cols-4 md:items-baseline md:gap-8">
                    <div class="absolute left-0 top-2 bottom-0 w-px bg-blue-200 md:hidden"></div>
                    <div class="absolute left-[-5px] top-2 w-2.5 h-2.5 rounded-full bg-blue-500 md:hidden border-2 border-[#fafafa] shadow-sm"></div>
                    
                    <div class="md:col-span-1 border-t-2 border-blue-500 w-12 mb-4 hidden md:block relative">
                        <div class="absolute right-[-4px] top-[-5px] w-2 h-2 rounded-full bg-blue-500"></div>
                    </div>
                    <div class="md:col-span-3 pb-10 border-b border-zinc-100/80 last:border-0 last:pb-0">
                        <div class="flex flex-col md:flex-row md:justify-between md:items-baseline mb-2">
                            <h3 class="text-xl md:text-2xl font-semibold text-zinc-900">PhD Researcher</h3>
                            <span class="inline-block py-1 px-3 rounded-full bg-zinc-100 text-xs text-zinc-600 font-semibold tabular-nums mt-2 md:mt-0 w-max">2021 — Present</span>
                        </div>
                        <div class="text-sm md:text-base text-blue-600 mb-4 font-serif italic">Worcester Polytechnic Institute (WPI)</div>
                        <p class="text-zinc-600 leading-relaxed font-light text-base md:text-lg">
                            Spearheading research on 5G/6G wireless infrastructure, efficient spectrum management, and optimizing O-RAN architecture. Developing novel approaches by integrating Machine Learning techniques—such as Continual and Reinforcement Learning—into physical-layer communications tasks to achieve higher network autonomy.
                        </p>
                    </div>
                </div>
                
                <!-- Role 2 -->
                <div class="relative pl-8 md:pl-0 md:grid md:grid-cols-4 md:items-baseline md:gap-8">
                    <div class="absolute left-0 top-2 bottom-0 w-px bg-zinc-200 md:hidden"></div>
                    <div class="absolute left-[-4px] top-2 w-2 h-2 rounded-full bg-zinc-400 md:hidden border-2 border-[#fafafa]"></div>
                    
                    <div class="md:col-span-1 border-t-2 border-zinc-300 w-12 mb-4 hidden md:block relative">
                        <div class="absolute right-[-3px] top-[-4px] w-1.5 h-1.5 rounded-full bg-zinc-400"></div>
                    </div>
                    <div class="md:col-span-3 pb-4">
                        <div class="flex flex-col md:flex-row md:justify-between md:items-baseline mb-2">
                            <h3 class="text-xl md:text-2xl font-semibold text-zinc-900">Data Scientist & Engineer</h3>
                            <span class="inline-block py-1 px-3 rounded-full bg-zinc-100 text-xs text-zinc-600 font-semibold tabular-nums mt-2 md:mt-0 w-max">2014 — 2021</span>
                        </div>
                        <div class="text-sm md:text-base text-zinc-500 mb-4 font-serif italic">MTN Group</div>
                        <p class="text-zinc-600 leading-relaxed font-light text-base md:text-lg">
                            Spent seven years driving impact in the telecommunications industry, specializing in large-scale data engineering. Built and maintained critical data infrastructure, developed predictive models, and implemented network optimization algorithms for global enterprise systems handling massive daily throughput.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section id="projects" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
            <div class="flex items-center mb-12">
                <h2 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="cpu" class="w-4 h-4 text-emerald-500"></i> Selected Works
                </h2>
                <div class="ml-6 h-px bg-zinc-200 flex-grow"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Project 1 -->
                <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
                    <div>
                        <div class="flex items-center justify-between mb-6">
                            <div class="p-3 bg-blue-50 text-blue-600 rounded-xl border border-blue-100">
                                <i data-lucide="radio" class="w-6 h-6"></i>
                            </div>
                            <div class="w-10 h-10 rounded-full border border-zinc-200 bg-white flex items-center justify-center group-hover:bg-zinc-900 group-hover:border-zinc-900 transition-colors shadow-sm">
                                <i data-lucide="arrow-up-right" class="w-5 h-5 text-zinc-400 group-hover:text-white transition-colors"></i>
                            </div>
                        </div>
                        <h3 class="text-2xl font-medium text-zinc-900 mb-3">WeaveMind</h3>
                        <p class="text-zinc-500 leading-relaxed font-light mb-8 text-base md:text-lg">
                            A novel pattern-driven beamforming architecture designed for 6G environments. It utilizes Local Context Memory and Stability Anchors to dramatically improve signal reliability and targeting in high-density areas.
                        </p>
                    </div>
                    <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 pt-6">
                        <span class="px-2 py-1 bg-zinc-100 rounded text-[10px] font-bold tracking-wider text-zinc-500 uppercase">Python</span>
                        <span class="px-2 py-1 bg-zinc-100 rounded text-[10px] font-bold tracking-wider text-zinc-500 uppercase">PyTorch</span>
                        <span class="px-2 py-1 bg-zinc-100 rounded text-[10px] font-bold tracking-wider text-zinc-500 uppercase">MATLAB</span>
                    </div>
                </a>

                <!-- Project 2 -->
                <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
                    <div>
                        <div class="flex items-center justify-between mb-6">
                            <div class="p-3 bg-emerald-50 text-emerald-600 rounded-xl border border-emerald-100">
                                <i data-lucide="shield-alert" class="w-6 h-6"></i>
                            </div>
                            <div class="w-10 h-10 rounded-full border border-zinc-200 bg-white flex items-center justify-center group-hover:bg-zinc-900 group-hover:border-zinc-900 transition-colors shadow-sm">
                                <i data-lucide="arrow-up-right" class="w-5 h-5 text-zinc-400 group-hover:text-white transition-colors"></i>
                            </div>
                        </div>
                        <h3 class="text-2xl font-medium text-zinc-900 mb-3">AI-Driven Fuzzing</h3>
                        <p class="text-zinc-500 leading-relaxed font-light mb-8 text-base md:text-lg">
                            A highly scalable framework for vulnerability analysis in 5G traffic steering algorithms. It employs NSGA-II multi-objective optimization to isolate hidden protocol weaknesses before they compromise network stability.
                        </p>
                    </div>
                    <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 pt-6">
                        <span class="px-2 py-1 bg-zinc-100 rounded text-[10px] font-bold tracking-wider text-zinc-500 uppercase">Security</span>
                        <span class="px-2 py-1 bg-zinc-100 rounded text-[10px] font-bold tracking-wider text-zinc-500 uppercase">Optimization</span>
                    </div>
                </a>
            </div>
        </section>

        <!-- Blog Section -->
        <section id="blog" class="mb-32 animate-fade-up delay-200 scroll-mt-24">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-12 gap-4">
                <div class="flex items-center flex-grow">
                    <h2 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="pen-tool" class="w-4 h-4 text-purple-500"></i> Articles & Thoughts
                    </h2>
                    <div class="ml-6 h-px bg-zinc-200 flex-grow"></div>
                </div>
                <a href="#" class="inline-flex items-center text-sm font-semibold text-zinc-500 hover:text-zinc-900 transition-colors group">
                    View All Posts <i data-lucide="arrow-right" class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Blog Post 1 -->
                <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Oct 12, 2025</span>
                            <span class="px-2 py-1 bg-purple-50 text-purple-600 rounded text-[10px] font-bold tracking-wider uppercase">Research</span>
                        </div>
                        <h3 class="text-xl md:text-2xl font-medium text-zinc-900 mb-3 group-hover:text-purple-600 transition-colors">The Future of 6G: Beyond Speed and Bandwidth</h3>
                        <p class="text-zinc-500 leading-relaxed font-light mb-6 text-base md:text-md">
                            Exploring how physical-layer machine learning and continuous adaptation will fundamentally restructure network deployments in the coming decade.
                        </p>
                    </div>
                    <div class="border-t border-zinc-100 pt-4 flex items-center text-sm font-medium text-zinc-800">
                        Read Article <i data-lucide="arrow-right" class="w-3.5 h-3.5 ml-2 text-zinc-400 group-hover:text-zinc-800 transition-all"></i>
                    </div>
                </a>

                <!-- Blog Post 2 -->
                <a href="#" class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl p-6 md:p-8">
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Aug 28, 2025</span>
                            <span class="px-2 py-1 bg-blue-50 text-blue-600 rounded text-[10px] font-bold tracking-wider uppercase">Engineering</span>
                        </div>
                        <h3 class="text-xl md:text-2xl font-medium text-zinc-900 mb-3 group-hover:text-blue-600 transition-colors">Transitioning from Academia to Telecom Enterprise Systems</h3>
                        <p class="text-zinc-500 leading-relaxed font-light mb-6 text-base md:text-md">
                            Lessons learned working with massive-scale data architectures at MTN Group, and how they shape my current approach to network optimization.
                        </p>
                    </div>
                    <div class="border-t border-zinc-100 pt-4 flex items-center text-sm font-medium text-zinc-800">
                        Read Article <i data-lucide="arrow-right" class="w-3.5 h-3.5 ml-2 text-zinc-400 group-hover:text-zinc-800 transition-all"></i>
                    </div>
                </a>
            </div>
        </section>

        <!-- Photography Section -->
        <section id="photography" class="mb-32 animate-fade-up delay-300 scroll-mt-24">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-12 gap-4">
                <div class="flex items-center flex-grow">
                    <h2 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="camera" class="w-4 h-4 text-zinc-500"></i> Local Perspectives
                    </h2>
                    <div class="ml-6 h-px bg-zinc-200 flex-grow"></div>
                </div>
                <a href="#" class="inline-flex items-center text-sm font-semibold text-zinc-500 hover:text-zinc-900 transition-colors group">
                    View Full Gallery <i data-lucide="arrow-right" class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
                <!-- Replace these with actual user photos -->
                <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-zinc-100 group relative cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-200/50 p-1">
                    <div class="w-full h-full rounded-xl overflow-hidden relative">
                        <img src="https://images.unsplash.com/photo-1580659325492-421ebefd71de?auto=format&fit=crop&q=80&w=800" alt="Los Angeles" class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700 ease-out grayscale group-hover:grayscale-0">
                        <div class="absolute inset-x-0 bottom-0 p-5 bg-gradient-to-t from-black/80 via-black/40 to-transparent">
                            <p class="text-white font-medium text-base">Cityscapes</p>
                            <p class="text-white/80 text-[11px] uppercase tracking-wider mt-1 font-semibold">Street Photography</p>
                        </div>
                    </div>
                </div>
                
                <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-zinc-100 group relative cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-200/50 p-1">
