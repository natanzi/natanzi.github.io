---
import '../styles/global.css';
import { 
    Menu, X, FileText, BookOpen, ArrowRight, ArrowUpRight, 
    Briefcase, Cpu, Radio, ShieldAlert, Network, Activity, Camera, PenTool, Database, Server, Code, Moon, Sun, Linkedin, Github, Mail
} from 'lucide-astro';
import siteSettings from '../data/settings.json';
import experienceData from '../data/experience.json';
import newsData from '../data/news.json';

// Import Section Components
import NewsSection from '../components/sections/NewsSection.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import BlogSection from '../components/sections/BlogSection.astro';

const pageTitle = "Milad Natanzi | ECE Researcher & Data Scientist";
const siteDescription = "Milad Natanzi is a PhD Candidate in ECE at WPI, blending 7+ years of telecom industry experience from MTN Group with advanced machine intelligence. Specializing in 5G/6G infrastructures and O-RAN.";
const siteUrl = "https://natanzi.com";
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{siteSettings.under_construction ? "Coming Soon | Milad Natanzi" : pageTitle}</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content={siteDescription}>
    <meta name="author" content="Milad Natanzi">
    <link rel="canonical" href={siteUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={siteUrl}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={siteDescription}>
    <meta property="og:image" content={`${siteUrl}/Milad-Natanzi.jpg`}>
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content={siteUrl}>
    <meta property="twitter:title" content={pageTitle}>
    <meta property="twitter:description" content={siteDescription}>
    <meta property="twitter:image" content={`${siteUrl}/Milad-Natanzi.jpg`}>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Milad Natanzi",
      "jobTitle": "PhD Candidate, ECE Researcher & Data Scientist",
      "url": "https://natanzi.com",
      "sameAs": [
        "https://www.linkedin.com/in/miladnatanzi",
        "https://github.com/natanzi"
      ]
    })} />

    <!-- Google Fonts: Inter, Newsreader, Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    
    <!-- Preload Hero Image -->
    <link rel="preload" href="/Milad-Natanzi.jpg" as="image" />
    
    <!-- Netlify Identity Widget -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
        body { 
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
        }
        .font-serif {
            font-family: 'Newsreader', serif;
        }
        .font-montserrat {
            font-family: 'Montserrat', sans-serif;
        }
        
        /* Nav Active State Underline */
        .nav-link { position: relative; }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px; left: 0;
            width: 100%; height: 2px;
            background-color: #3b82f6;
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.3s ease;
        }
        .nav-link.active { color: #3b82f6; font-weight: 500; }
        .dark .nav-link.active { color: #60a5fa; }
        .nav-link.active::after {
            transform: scaleX(1);
            transform-origin: left;
        }
        
        /* Refined animations */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up {
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 150ms; }
        .delay-200 { animation-delay: 300ms; }
        .delay-300 { animation-delay: 450ms; }
        
        /* Glass styling */
        .glass-nav {
            background: rgba(250, 250, 250, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        }
        
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
        }
        
        .dark .glass-card {
            background: rgba(24, 24, 27, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2), 0 2px 4px -1px rgba(0, 0, 0, 0.1);
        }

        .glass-card-hover {
            transition: all 0.3s ease;
        }
        .glass-card-hover:hover {
            background: rgba(255, 255, 255, 1);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.025);
            border-color: rgba(0,0,0,0.08);
        }
        
        /* Subtle background glow effect */
        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, rgba(250, 250, 250, 0) 70%);
        }
        .bg-glow::after {
            content: '';
            position: absolute;
            bottom: -10%; left: -5%;
            width: 60vw; height: 60vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.03) 0%, rgba(250, 250, 250, 0) 70%);
        }

        /* Image Masking for Hero */
        .hero-image-mask {
            mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
        }

        /* Gradient Text */
        .text-gradient-light {
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-image: linear-gradient(135deg, #3b82f6 0%, #10b981 100%);
        }
        
        /* Mobile menu open state */
        .mobile-menu-active {
            display: flex !important;
        }
        .no-scroll {
            overflow: hidden;
        }
        
        /* Dark Mode bg glow */
        .dark .bg-glow::before { background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, rgba(9, 9, 11, 0) 70%); }
        .dark .bg-glow::after { background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, rgba(9, 9, 11, 0) 70%); }
        .dark .glass-nav {
            background: rgba(9, 9, 11, 0.7);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }
    </style>
    
    <!-- Initialize Theme Script -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class={siteSettings.under_construction ? "antialiased flex items-center justify-center min-h-screen relative overflow-hidden bg-zinc-50 dark:bg-zinc-950 transition-colors duration-300" : "text-zinc-800 dark:text-zinc-300 antialiased selection:bg-zinc-200 dark:selection:bg-zinc-800 selection:text-zinc-900 dark:selection:text-white min-h-screen relative bg-[#fafafa] dark:bg-zinc-950 transition-colors duration-300"}>

{siteSettings.under_construction ? (
    <Fragment>
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-100 to-zinc-200 z-0"></div>
        <div class="relative z-10 text-center px-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white dark:bg-zinc-900 shadow-xl mb-8 border border-transparent dark:border-zinc-800">
                <Hammer class="w-8 h-8 text-zinc-900 dark:text-zinc-100" />
            </div>
            <h1 class="text-5xl md:text-6xl font-serif text-zinc-900 dark:text-white mb-6">Under Construction</h1>
            <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-md mx-auto">I'm currently updating my portfolio. Please check back shortly.</p>
        </div>
    </Fragment>
) : (
    <Fragment>
    <div class="bg-glow"></div>

    <!-- Sticky Navigation Bar -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300" id="main-nav">
        <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="#" class="font-sans text-[1.35rem] font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-zinc-900 to-zinc-500 dark:from-zinc-100 dark:to-zinc-400 hover:opacity-80 transition-opacity">
                Milad Natanzi
            </a>
            
            <div class="hidden md:flex items-center space-x-8 text-[13px] font-montserrat font-normal tracking-[0.5px] text-zinc-500 dark:text-zinc-400 capitalize">
                <a href="#about" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">About</a>
                <a href="#news" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">News</a>
                <a href="#experience" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Experience</a>
                <a href="#projects" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Projects</a>
                <a href="#blog" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Blog</a>
                <a href="/gallery" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Out of office</a>
            </div>
            
            <div class="flex items-center space-x-4">
                <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800 hidden md:block">
                    <Sun class="hidden dark:block w-4 h-4" />
                    <Moon class="block dark:hidden w-4 h-4" />
                </button>
                <a href="mailto:milad@natanzi.com" class="hidden md:inline-flex items-center justify-center px-5 py-2 text-[13px] font-montserrat font-medium tracking-[0.5px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-colors shadow-sm">
                    Let's Talk
                </a>
            </div>
            
            <!-- Mobile Menu Toggle -->
            <button id="mobile-menu-btn" class="md:hidden text-zinc-500 hover:text-zinc-900 p-2 -mr-2 focus:outline-none">
                <div id="icon-menu-wrapper"><Menu class="w-6 h-6" /></div>
                <div id="icon-close-wrapper" class="hidden"><X class="w-6 h-6" /></div>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-white/95 backdrop-blur-md z-40 hidden flex-col justify-center items-center space-y-8 opacity-0 transition-opacity duration-300 pt-16">
        <a href="#about" class="mobile-link text-2xl font-montserrat font-light text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors capitalize">About</a>
        <a href="#news" class="mobile-link text-2xl font-montserrat font-light text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors capitalize">News</a>
        <a href="#experience" class="mobile-link text-2xl font-montserrat font-light text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors capitalize">Experience</a>
        <a href="#projects" class="mobile-link text-2xl font-montserrat font-light text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors capitalize">Projects</a>
        <a href="#blog" class="mobile-link text-2xl font-montserrat font-light text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors capitalize">Blog</a>
        <a href="/gallery" class="mobile-link text-2xl font-montserrat font-light text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors capitalize">Out of office</a>
        <a href="mailto:milad@natanzi.com" class="mobile-link mt-8 px-8 py-3 text-[15px] font-montserrat font-medium tracking-[0.5px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full shadow-md">
            Let's Talk
        </a>
    </div>

    <main class="max-w-5xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
        
        <!-- Hero Section with Image Split -->
        <header id="about" class="mb-32 animate-fade-up">
            <div class="flex flex-col-reverse lg:flex-row gap-12 lg:gap-16 items-center lg:items-center">
                
                <!-- Text Content -->
                <div class="flex-1 w-full">
                    {siteSettings.show_job_market_status && (
                        <div class="inline-flex items-center space-x-2 px-3 py-1.5 rounded-full bg-white border border-zinc-200 shadow-sm mb-8">
                            <span class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                            </span>
                            <span class="text-[11px] font-semibold text-zinc-600 uppercase tracking-widest pl-1">I am in job market now</span>
                        </div>
                    )}
                    

                    
                    <div class="text-base md:text-lg text-zinc-600 dark:text-zinc-400 font-light leading-relaxed mb-8 max-w-2xl space-y-4">
                        <p>
                            Hello! I am Milad, a Ph.D. Candidate and researcher in the Department of Electrical and Computer Engineering at <strong class="text-zinc-800 dark:text-zinc-200 font-medium">Worcester Polytechnic Institute (WPI)</strong>.
                        </p>
                        <p>
                            My research bridges the gap between advanced artificial intelligence and next-generation telecommunications. Specifically, my interests focus on:
                        </p>
                        <ul class="list-disc pl-5 space-y-1">
                            <li>5G and 6G wireless infrastructure and O-RAN architecture.</li>
                            <li>Beamforming optimization and spectrum management.</li>
                            <li>Integrating Machine Learning (Continual & Reinforcement Learning) into physical-layer systems.</li>
                            <li>Building and managing high-performance GPU clusters and software-defined radio (SDR) environments.</li>
                        </ul>
                        <p>
                            Prior to my academic career, I spent over seven years as a Data Scientist and Engineer in the telecommunications industry, working with global enterprise systems including the MTN Group. I am currently completing my Ph.D. under the supervision of Dr. Bo Tang.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-2 mb-10 max-w-2xl">
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">5G/6G Networks</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">Machine Learning</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">Python</span>
                        <span class="px-3 py-1 text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm">O-RAN</span>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 max-w-md">
                        <a href="#" class="group flex items-center justify-between px-5 py-4 glass-card glass-card-hover rounded-xl w-full">
                            <div class="flex items-center text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                                <span class="bg-blue-50 dark:bg-blue-900/30 p-2 rounded-lg mr-3 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/50 transition-colors">
                                    <FileText class="w-4 h-4 text-blue-600 dark:text-blue-400" />
                                </span>
                                Read My CV
                            </div>
                            <ArrowRight class="w-4 h-4 text-zinc-400 dark:text-zinc-500 group-hover:text-zinc-800 dark:group-hover:text-zinc-300 group-hover:translate-x-1 transition-all" />
                        </a>
                        <a href="#" class="group flex items-center justify-between px-5 py-4 glass-card glass-card-hover rounded-xl w-full">
                            <div class="flex items-center text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                                <span class="bg-emerald-50 dark:bg-emerald-900/30 p-2 rounded-lg mr-3 group-hover:bg-emerald-100 dark:group-hover:bg-emerald-900/50 transition-colors">
                                    <BookOpen class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />
                                </span>
                                Publications
                            </div>
                            <ArrowRight class="w-4 h-4 text-zinc-400 dark:text-zinc-500 group-hover:text-zinc-800 dark:group-hover:text-zinc-300 group-hover:translate-x-1 transition-all" />
                        </a>
                    </div>
                </div>

                <!-- Image Profile (Hero) -->
                <div class="w-full lg:w-5/12 max-w-md mx-auto lg:mx-0 relative lg:pl-8">
                    <div class="absolute -inset-4 bg-gradient-to-tr from-blue-100 via-emerald-50 to-transparent rounded-3xl blur-2xl opacity-50 z-0"></div>
                    <div class="relative z-10 aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl shadow-zinc-200/50 border border-white bg-white">
                        <!-- Placeholder Image (Replace with user's actual photo) -->
                        <img src="/Milad-Natanzi.jpg" 
                             alt="Milad" 
                             class="w-full h-full object-cover object-center hero-image-mask hover:scale-105 transition-transform duration-1000 ease-out" />
                    </div>
                </div>

            </div>
        </header>

        </header>

        <!-- Dynamic CMS-Driven Sections -->
        {siteSettings.layout && siteSettings.layout.map((item) => {
            if (!item.visible) return null;
            
            switch (item.section) {
                case 'news': return <NewsSection />;
                case 'experience': return <ExperienceSection />;
                case 'skills': return <SkillsSection />;
                case 'projects': return <ProjectsSection />;
                case 'blog': return <BlogSection />;
                default: return null;
            }
        })}

        <!-- Out of Office / Gallery Section -->
        <section id="photography" class="mb-32 animate-fade-up delay-300 scroll-mt-24">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between mb-8 gap-4">
                <div>
                    <div class="flex items-center mb-3">
                        <Camera class="w-4 h-4 text-zinc-500 dark:text-zinc-400 mr-2" />
                        <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-widest">Out of Office</h2>
                        <div class="ml-6 h-px bg-zinc-200 dark:bg-zinc-800 flex-grow w-24"></div>
                    </div>
                    <p class="text-zinc-500 dark:text-zinc-400 font-light text-base leading-relaxed max-w-lg italic font-serif">
                        Stepping away from the servers and lab to capture the world in focus.
                    </p>
                </div>
                <a href="/gallery" class="inline-flex items-center text-sm font-semibold text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group shrink-0 mt-2 sm:mt-0">
                    View Full Gallery <ArrowRight class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" />
                </a>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
                <!-- Chicago -->
                <a href="/gallery/chicago" class="group aspect-[4/5] rounded-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 relative shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-200/50 dark:border-zinc-800/50">
                    <img src="https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?auto=format&fit=crop&q=80&w=800" alt="Chicago" class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700 ease-out grayscale group-hover:grayscale-0" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
                    <div class="absolute inset-x-0 bottom-0 p-5">
                        <p class="text-white/60 text-[11px] uppercase tracking-wider font-semibold mb-1">8 Photos</p>
                        <p class="text-white font-serif text-xl">Chicago</p>
                        <p class="text-white/70 text-xs mt-1 font-light">The Windy City from ground to sky</p>
                    </div>
                    <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="bg-white/90 text-zinc-900 text-xs font-bold px-3 py-1 rounded-full">Browse →</span>
                    </div>
                </a>
                
                <!-- Boston -->
                <a href="/gallery/boston" class="group aspect-[4/5] rounded-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 relative shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-200/50 dark:border-zinc-800/50">
                    <img src="https://images.unsplash.com/photo-1501979376754-4ff580d7e73b?auto=format&fit=crop&q=80&w=800" alt="Boston" class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700 ease-out grayscale group-hover:grayscale-0" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
                    <div class="absolute inset-x-0 bottom-0 p-5">
                        <p class="text-white/60 text-[11px] uppercase tracking-wider font-semibold mb-1">6 Photos</p>
                        <p class="text-white font-serif text-xl">Boston</p>
                        <p class="text-white/70 text-xs mt-1 font-light">History meets modernity in the Bay State</p>
                    </div>
                    <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="bg-white/90 text-zinc-900 text-xs font-bold px-3 py-1 rounded-full">Browse →</span>
                    </div>
                </a>
                
                <!-- New York City -->
