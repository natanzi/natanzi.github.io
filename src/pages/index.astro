    <!-- Main JS Scripts -->
    <script>
        // Add subtle style change to nav on scroll
        const nav = document.getElementById('main-nav');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) {
                nav.classList.add('shadow-sm');
                if(!document.documentElement.classList.contains('dark')) {
                    nav.style.background = 'rgba(255, 255, 255, 0.9)';
                }
            } else {
                nav.classList.remove('shadow-sm');
                if(!document.documentElement.classList.contains('dark')) {
                    nav.style.background = 'rgba(250, 250, 250, 0.7)';
                } else {
                    nav.style.background = 'rgba(9, 9, 11, 0.7)';
                }
            }
        });

        // Mobile Menu Toggle Logic
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const iconMenuWrapper = document.getElementById('icon-menu-wrapper');
        const iconCloseWrapper = document.getElementById('icon-close-wrapper');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        
        let menuOpen = false;

        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('theme-toggle');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', function() {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                }
            });
        }

        function toggleMenu() {
            menuOpen = !menuOpen;
            if (menuOpen) {
                mobileMenu.classList.remove('hidden');
                setTimeout(() => {
                    mobileMenu.classList.remove('opacity-0');
                    mobileMenu.classList.add('opacity-100');
                    document.body.classList.add('no-scroll');
                    iconMenuWrapper.classList.add('hidden');
                    iconCloseWrapper.classList.remove('hidden');
                }, 10);
            } else {
                mobileMenu.classList.remove('opacity-100');
                mobileMenu.classList.add('opacity-0');
                document.body.classList.remove('no-scroll');
                iconCloseWrapper.classList.add('hidden');
                iconMenuWrapper.classList.remove('hidden');
                
                // Wait for fade out before hiding
                setTimeout(() => {
                    mobileMenu.classList.add('hidden');
                }, 300);
            }
        }

        mobileBtn.addEventListener('click', toggleMenu);

        // Close menu when clicking a link
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                if(menuOpen) toggleMenu();
            });
        });

        // ── Smooth scroll WITHOUT adding # to URL ──────────────────────────
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const hash = this.getAttribute('href');
                if (!hash || hash === '#') return;
                const target = document.querySelector(hash);
                if (!target) return;
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                // Keep URL clean — no hash appended
                history.replaceState(null, '', window.location.pathname);
            });
        });

        // Netlify Identity Login Redirect Tracker
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", user => {
            if (!user) {
                window.netlifyIdentity.on("login", () => {
                document.location.href = "/admin/";
                });
            }
            });
        }

        // Active Menu State via IntersectionObserver
        const sections = document.querySelectorAll('section[id], header[id="about"]');
        const navLinks = document.querySelectorAll('.nav-link');

        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.2 // Trigger when 20% of section is visible
        };

        const sectionObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute('id');
                    // Remove active from all and add to current target
                    navLinks.forEach(link => {
                        link.classList.remove('active');
                        if (link.getAttribute('href') === `#${id}`) {
                            link.classList.add('active');
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach(section => {
            sectionObserver.observe(section);
        });
    </script>
</body>
