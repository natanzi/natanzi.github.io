---
import '../../styles/global.css';
import { ArrowLeft, Sun, Moon, ArrowUpRight, Activity } from 'lucide-astro';
import newsData from '../../data/news.json';
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>News & Updates | Milad Natanzi</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content="All news, updates, and announcements from Milad Natanzi.">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Newsreader', serif; }
        .font-montserrat { font-family: 'Montserrat', sans-serif; }
        
        .glass-nav {
            background: rgba(250, 250, 250, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .dark .glass-nav {
            background: rgba(9, 9, 11, 0.9);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; left: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, rgba(250, 250, 250, 0) 70%);
        }
        
        .dark .bg-glow::before {
            background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, rgba(9, 9, 11, 0) 70%);
        }
    </style>
    
    <!-- Initialize Theme Script -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-[#fafafa] dark:bg-zinc-950 text-zinc-900 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300">

    <div class="bg-glow"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300">
        <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/" class="flex items-center text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors group">
                <ArrowLeft class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Home
            </a>
            
            <div class="flex items-center space-x-4">
                <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800">
                    <Sun class="hidden dark:block w-4 h-4" />
                    <Moon class="block dark:hidden w-4 h-4" />
                </button>
            </div>
        </div>
    </nav>

    <main class="max-w-3xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
        <header class="mb-16">
            <div class="inline-flex items-center justify-center p-3 rounded-2xl bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 mb-6">
                <Activity class="w-6 h-6" />
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-zinc-900 dark:text-white mb-4 font-montserrat tracking-tight">
                All News & Updates
            </h1>
            <p class="text-zinc-500 dark:text-zinc-400 text-lg">
                A chronological timeline of my papers, talks, and professional milestones.
            </p>
        </header>

        <div class="relative border-l border-zinc-200 dark:border-zinc-800 ml-3 md:ml-4 pb-8 space-y-12">
            {newsData.news.map((item) => (
                <div class="relative pl-8 md:pl-10 group">
                    <div class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-zinc-300 dark:bg-zinc-700 ring-4 ring-[#fafafa] dark:ring-zinc-950 group-hover:bg-blue-500 transition-colors"></div>
                    
                    <span class="block text-xs font-bold tracking-widest text-zinc-400 dark:text-zinc-500 uppercase mb-2">
                        {item.date}
                    </span>
                    
                    <div class="text-zinc-800 dark:text-zinc-200 text-base md:text-lg leading-relaxed font-light">
                        {item.content}
                    </div>
                    
                    {item.link && (
                        <a href={item.link} target={item.link.startsWith('http') ? "_blank" : "_self"} class="inline-flex items-center mt-3 text-sm font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors group/link">
                            Read More <ArrowUpRight class="w-4 h-4 ml-1 opacity-50 group-hover/link:opacity-100 transition-opacity" />
                        </a>
                    )}
                </div>
            ))}
        </div>
    </main>

    <footer class="mt-12 py-10 border-t border-zinc-200 dark:border-zinc-800 text-center text-sm font-medium text-zinc-500 dark:text-zinc-400">
        © 2026 Milad Natanzi. All rights reserved.
    </footer>

    <!-- Scripts -->
    <script>
        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('theme-toggle');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', function() {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                }
            });
        }
    </script>
</body>
</html>
