---
import * as Icons from 'lucide-astro';
import { Sun, Moon, Menu, X, ArrowLeft, ArrowUpRight, Cpu, Link as LinkIcon } from 'lucide-astro';
import projectsData from '../../data/projects.json';
import { marked } from 'marked';
import '../../styles/global.css';

export async function getStaticPaths() {
    return projectsData.projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { project } = Astro.props;

const getIcon = (iconName) => {
    return Icons[iconName] || Icons.Code;
};

const colors = [
    {
        bg: "bg-blue-50 dark:bg-blue-900/30",
        text: "text-blue-600 dark:text-blue-400",
        border: "border-blue-100 dark:border-blue-800/50"
    },
    {
        bg: "bg-emerald-50 dark:bg-emerald-900/30",
        text: "text-emerald-600 dark:text-emerald-400",
        border: "border-emerald-100 dark:border-emerald-800/50"
    },
    {
        bg: "bg-purple-50 dark:bg-purple-900/30",
        text: "text-purple-600 dark:text-purple-400",
        border: "border-purple-100 dark:border-purple-800/50"
    },
    {
        bg: "bg-rose-50 dark:bg-rose-900/30",
        text: "text-rose-600 dark:text-rose-400",
        border: "border-rose-100 dark:border-rose-800/50"
    }
];

// Base the color theme off the project index to keep it consistent with projects list page
const projectIndex = projectsData.projects.findIndex(p => p.slug === project.slug);
const theme = colors[projectIndex !== -1 ? projectIndex % colors.length : 0];
const IconComponent = getIcon(project.icon);

const canonicalUrl = new URL(Astro.url.pathname, "https://natanzi.com").href;
const title = `${project.title} | Milad Natanzi`;
const description = project.description;
---

<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content={description}>
    <meta name="author" content="Milad Natanzi">
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://natanzi.com/Milad-Natanzi.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://natanzi.com/Milad-Natanzi.jpg" />

    <!-- JSON-LD Breadcrumbs -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://natanzi.com"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Projects",
          "item": "https://natanzi.com/projects"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": project.title,
          "item": canonicalUrl
        }
      ]
    })} />

    <!-- JSON-LD CreativeWork -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      "name": project.title,
      "description": project.description,
      "url": canonicalUrl,
      "author": {
        "@type": "Person",
        "name": "Milad Natanzi",
        "url": "https://natanzi.com"
      },
      "keywords": project.tags
    })} />
    
    <!-- Google Fonts: Inter, Newsreader, Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Newsreader', serif; }
        .font-montserrat { font-family: 'Montserrat', sans-serif; }
        
        .glass-nav {
            background: rgba(250, 250, 250, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.04);
        }
        .dark .glass-nav {
            background: rgba(9, 9, 11, 0.85);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
        }
        .dark .glass-card {
            background: rgba(24, 24, 27, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2), 0 2px 4px -1px rgba(0, 0, 0, 0.1);
        }
        
        .bg-glow {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        .bg-glow::before {
            content: '';
            position: absolute;
            top: -10%; right: -5%;
            width: 50vw; height: 50vw;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.03) 0%, rgba(250, 250, 250, 0) 70%);
        }
        .dark .bg-glow::before {
            background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, rgba(9, 9, 11, 0) 70%);
        }

        /* Prose styles for dynamic content */
        .prose h1, .prose h2, .prose h3 {
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            color: #18181b;
            margin-top: 2rem;
            margin-bottom: 1rem;
        }
        .dark .prose h1, .dark .prose h2, .dark .prose h3 {
            color: #f4f4f5;
        }
        .prose p {
            line-height: 1.75;
            margin-bottom: 1.5rem;
            font-weight: 300;
        }
        .prose ul, .prose ol {
            margin-bottom: 1.5rem;
            padding-left: 1.5rem;
        }
        .prose li {
            list-style-type: decimal;
            margin-bottom: 0.5rem;
            font-weight: 300;
        }
        .prose ul li {
            list-style-type: disc;
        }
    </style>
    
    <!-- Initialize Theme Script -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-[#fafafa] dark:bg-zinc-950 text-zinc-900 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300">

    <div class="bg-glow"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300" id="main-nav">
        <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/projects" class="flex items-center text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors group">
                <ArrowLeft class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" /> Back
            </a>
            
            <div class="hidden md:flex items-center space-x-8 text-[13px] font-montserrat font-normal tracking-[0.5px] text-zinc-500 dark:text-zinc-400 capitalize">
                <a href="/#about" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">About</a>
                <a href="/#news" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">News</a>
                <a href="/cv" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">CV</a>
                <a href="/#experience" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Experience</a>
                <a href="/projects" class="nav-link py-1 text-zinc-900 dark:text-white transition-colors font-medium">Projects</a>
                <a href="/#blog" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Blog</a>
                <a href="/gallery" class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors">Travel</a>
            </div>
            
            <div class="flex items-center space-x-4">
                <button id="theme-toggle" class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800 hidden md:block">
                    <Sun class="hidden dark:block w-4 h-4" />
                    <Moon class="block dark:hidden w-4 h-4" />
                </button>
                <a href="mailto:milad@natanzi.com" class="hidden md:inline-flex items-center justify-center px-5 py-2 text-[13px] font-montserrat font-medium tracking-[0.5px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-colors shadow-sm">
                    Let's Talk
                </a>
            </div>
            
            <!-- Mobile Menu Toggle -->
            <button id="mobile-menu-btn" class="md:hidden text-zinc-500 hover:text-zinc-900 p-2 -mr-2 focus:outline-none">
                <div id="icon-menu-wrapper"><Menu class="w-6 h-6" /></div>
                <div id="icon-close-wrapper" class="hidden"><X class="w-6 h-6" /></div>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-white/98 dark:bg-zinc-950/98 backdrop-blur-xl z-[60] hidden flex-col justify-center items-center opacity-0 transition-opacity duration-300">
        <nav class="flex flex-col items-center space-y-7 w-full px-6">
            <a href="/#about" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize">About</a>
            <a href="/#news" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize">News</a>
            <a href="/cv" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize">CV</a>
            <a href="/#experience" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize">Experience</a>
            <a href="/projects" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white transition-colors capitalize">Projects</a>
            <a href="/#blog" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize">Blog</a>
            <a href="/gallery" class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white transition-colors capitalize">Travel</a>
            
            <div class="pt-8 w-full max-w-[240px]">
                <a href="mailto:milad@natanzi.com" class="mobile-link flex items-center justify-center px-6 py-4 text-[15px] font-montserrat font-medium tracking-[1px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full shadow-lg active:scale-95 transition-transform uppercase">
                    Let's Talk
                </a>
            </div>
        </nav>
    </div>

    <main class="max-w-4xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
        <!-- Hero Image -->
        {project.image && (
            <div class="relative w-full aspect-[21/9] md:aspect-[24/10] overflow-hidden rounded-3xl mb-12 shadow-xl border border-white dark:border-zinc-800 bg-white">
                <img src={project.image} alt={project.title} class="w-full h-full object-cover" />
            </div>
        )}

        <!-- Hero header card -->
        <div class="glass-card rounded-3xl p-8 md:p-12 mb-12 relative overflow-hidden">
            <div class="absolute -inset-4 bg-gradient-to-tr from-blue-100/20 via-emerald-50/15 to-transparent dark:from-blue-900/10 dark:via-zinc-850/10 rounded-3xl blur-2xl z-0"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row md:items-start justify-between gap-8">
                <div class="flex-grow">
                    <div class="flex items-center gap-4 mb-6">
                        <div class={`p-3.5 rounded-xl border ${theme.bg} ${theme.text} ${theme.border}`}>
                            <IconComponent class="w-7 h-7" />
                        </div>
                        <span class="text-xs font-semibold tracking-widest text-zinc-400 dark:text-zinc-500 uppercase">Project Profile</span>
                    </div>
                    
                    <h1 class="text-4xl md:text-5xl font-extrabold text-zinc-900 dark:text-white mb-6 font-montserrat tracking-tight">
                        {project.title}
                    </h1>
                    
                    <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-light text-base md:text-lg mb-8 max-w-2xl">
                        {project.description}
                    </p>
                    
                    <div class="flex flex-wrap gap-2.5">
                        {project.tags && project.tags.map((tag) => (
                            <span class="px-3.5 py-1.5 text-xs font-semibold tracking-wider text-zinc-700 dark:text-zinc-300 bg-zinc-100 dark:bg-zinc-800 border border-zinc-200/50 dark:border-zinc-700/50 rounded-lg">
                                {tag}
                            </span>
                        ))}
                    </div>
                </div>
                
                {project.external_url && (
                    <a
                        href={project.external_url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center px-6 py-3.5 text-sm font-semibold tracking-wide text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-xl hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-colors shadow-md shrink-0 self-start mt-2"
                    >
                        <LinkIcon class="w-4 h-4 mr-2" /> View Repository <ArrowUpRight class="w-4 h-4 ml-1 opacity-70" />
                    </a>
                )}
            </div>
        </div>

        <!-- Detailed Project Body Content -->
        <article class="prose prose-zinc dark:prose-invert prose-lg max-w-none px-4">
            <div set:html={marked.parse(project.content || '')}></div>
        </article>
        
        <div class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800 flex items-center justify-between">
            <a href="/projects" class="text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1.5">
                ← Back to all projects
            </a>
        </div>
    </main>

    <footer class="py-10 border-t border-zinc-200 dark:border-zinc-800 text-center text-sm font-medium text-zinc-500 dark:text-zinc-400">
        © 2026 Milad Natanzi. All rights reserved.
    </footer>

    <script>
        // Mobile Menu Toggle Logic
        const mobileBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const iconMenuWrapper = document.getElementById("icon-menu-wrapper");
        const iconCloseWrapper = document.getElementById("icon-close-wrapper");
        const mobileLinks = document.querySelectorAll(".mobile-link");

        let menuOpen = false;

        document.getElementById("theme-toggle")?.addEventListener("click", () => {
            if (document.documentElement.classList.contains("dark")) {
                document.documentElement.classList.remove("dark");
                localStorage.setItem("theme", "light");
            } else {
                document.documentElement.classList.add("dark");
                localStorage.setItem("theme", "dark");
            }
        });

        function toggleMenu() {
            if (!mobileBtn) return;
            menuOpen = !menuOpen;
            if (menuOpen) {
                mobileMenu.classList.remove("hidden");
                setTimeout(() => {
                    mobileMenu.classList.remove("opacity-0");
                    mobileMenu.classList.add("opacity-100");
                    document.body.classList.add("no-scroll");
                    iconMenuWrapper.classList.add("hidden");
                    iconCloseWrapper.classList.remove("hidden");
                }, 10);
            } else {
                mobileMenu.classList.remove("opacity-100");
                mobileMenu.classList.add("opacity-0");
                document.body.classList.remove("no-scroll");
                iconCloseWrapper.classList.add("hidden");
                iconMenuWrapper.classList.remove("hidden");

                setTimeout(() => {
                    mobileMenu.classList.add("hidden");
                }, 300);
            }
        }

        if (mobileBtn) {
            mobileBtn.addEventListener("click", toggleMenu);
        }

        mobileLinks.forEach((link) => {
            link.addEventListener("click", () => {
                if (menuOpen) toggleMenu();
            });
        });
    </script>
</body>
</html>
