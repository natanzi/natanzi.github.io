---
import * as Icons from 'lucide-astro';
import { Sun, Moon, Menu, X, ArrowUpRight, Cpu, ArrowRight } from "lucide-astro";
import projectsData from "../../data/projects.json";
import "../../styles/global.css";

const getIcon = (iconName) => {
    return Icons[iconName] || Icons.Code;
};

const colors = [
    {
        bg: "bg-blue-50 dark:bg-blue-900/30",
        text: "text-blue-600 dark:text-blue-400",
        border: "border-blue-100 dark:border-blue-800/50"
    },
    {
        bg: "bg-emerald-50 dark:bg-emerald-900/30",
        text: "text-emerald-600 dark:text-emerald-400",
        border: "border-emerald-100 dark:border-emerald-800/50"
    },
    {
        bg: "bg-purple-50 dark:bg-purple-900/30",
        text: "text-purple-600 dark:text-purple-400",
        border: "border-purple-100 dark:border-purple-800/50"
    },
    {
        bg: "bg-rose-50 dark:bg-rose-900/30",
        text: "text-rose-600 dark:text-rose-400",
        border: "border-rose-100 dark:border-rose-800/50"
    }
];

const getColorTheme = (index) => {
    return colors[index % colors.length];
};

const canonicalUrl = new URL(Astro.url.pathname, "https://natanzi.com").href;
const title = "Selected Works & Projects | Milad Natanzi";
const description = "Explore the selected projects and research works of Milad Natanzi, specializing in 5G/6G infrastructures, O-RAN, and AI/ML optimization.";
---

<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="https://natanzi.com/Milad-Natanzi.jpg" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalUrl} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content="https://natanzi.com/Milad-Natanzi.jpg" />

        <!-- JSON-LD Breadcrumbs -->
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://natanzi.com"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Projects",
              "item": canonicalUrl
            }
          ]
        })} />

        <!-- JSON-LD Collection Page -->
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "CollectionPage",
          "name": "Selected Works & Projects of Milad Natanzi",
          "description": description,
          "url": canonicalUrl,
          "mainEntity": {
            "@type": "ItemList",
            "numberOfItems": projectsData.projects.length,
            "itemListElement": projectsData.projects.map((proj, idx) => ({
              "@type": "ListItem",
              "position": idx + 1,
              "url": `https://natanzi.com/projects/${proj.slug}`
            }))
          }
        })} />

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap"
            rel="stylesheet"
        />

        <style>
            body {
                font-family: "Inter", sans-serif;
            }
            .font-serif {
                font-family: "Newsreader", serif;
            }
            .font-montserrat {
                font-family: "Montserrat", sans-serif;
            }

            .glass-nav {
                background: rgba(250, 250, 250, 0.85);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border-bottom: 1px solid rgba(0, 0, 0, 0.04);
            }
            .dark .glass-nav {
                background: rgba(9, 9, 11, 0.85);
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }

            .glass-card {
                background: rgba(255, 255, 255, 0.8);
                border: 1px solid rgba(0, 0, 0, 0.05);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
            }
            .dark .glass-card {
                background: rgba(24, 24, 27, 0.6);
                border: 1px solid rgba(255, 255, 255, 0.05);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2), 0 2px 4px -1px rgba(0, 0, 0, 0.1);
            }

            .glass-card-hover {
                transition: all 0.3s ease;
            }
            .glass-card-hover:hover {
                background: rgba(255, 255, 255, 1);
                transform: translateY(-2px);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.025);
                border-color: rgba(0,0,0,0.08);
            }

            .bg-glow {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                overflow: hidden;
                z-index: -1;
                pointer-events: none;
            }
            .bg-glow::before {
                content: "";
                position: absolute;
                top: -10%;
                left: -5%;
                width: 50vw;
                height: 50vw;
                border-radius: 50%;
                background: radial-gradient(
                    circle,
                    rgba(59, 130, 246, 0.04) 0%,
                    rgba(250, 250, 250, 0) 70%
                );
            }

            .dark .bg-glow::before {
                background: radial-gradient(
                    circle,
                    rgba(59, 130, 246, 0.08) 0%,
                    rgba(9, 9, 11, 0) 70%
                );
            }
        </style>

        <!-- Initialize Theme Script -->
        <script is:inline>
            if (
                localStorage.getItem("theme") === "dark" ||
                (!("theme" in localStorage) &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches)
            ) {
                document.documentElement.classList.add("dark");
            } else {
                document.documentElement.classList.remove("dark");
            }
        </script>
    </head>

    <body
        class="bg-[#fafafa] dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 antialiased min-h-screen transition-colors duration-300"
    >
        <div class="bg-glow"></div>

        <!-- Navigation -->
        <nav
            class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300"
            id="main-nav"
        >
            <div
                class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between"
            >
                <a
                    href="/"
                    class="font-sans text-[1.35rem] font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-zinc-900 to-zinc-500 dark:from-zinc-100 dark:to-zinc-400 hover:opacity-80 transition-opacity"
                >
                    Milad Natanzi
                </a>

                <div
                    class="hidden md:flex items-center space-x-8 text-[13px] font-montserrat font-normal tracking-[0.5px] text-zinc-500 dark:text-zinc-400 capitalize"
                >
                    <a
                        href="/#about"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >About</a
                    >
                    <a
                        href="/#news"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >News</a
                    >
                    <a
                        href="/cv"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >CV</a
                    >
                    <a
                        href="/#experience"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >Experience</a
                    >
                    <a
                        href="/projects"
                        class="nav-link py-1 text-zinc-900 dark:text-white transition-colors font-medium"
                        >Projects</a
                    >
                    <a
                        href="/#blog"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >Blog</a
                    >
                    <a
                        href="/gallery"
                        class="nav-link py-1 hover:text-zinc-900 dark:hover:text-white transition-colors"
                        >Travel</a
                    >
                </div>

                <div class="flex items-center space-x-4">
                    <button
                        id="theme-toggle"
                        class="p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors focus:outline-none rounded-full border border-transparent hover:border-zinc-200 dark:hover:border-zinc-800 hidden md:block"
                    >
                        <Sun class="hidden dark:block w-4 h-4" />
                        <Moon class="block dark:hidden w-4 h-4" />
                    </button>
                    <a
                        href="mailto:milad@natanzi.com"
                        class="hidden md:inline-flex items-center justify-center px-5 py-2 text-[13px] font-montserrat font-medium tracking-[0.5px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-colors shadow-sm"
                    >
                        Let's Talk
                    </a>
                </div>

                <!-- Mobile Menu Toggle -->
                <button
                    id="mobile-menu-btn"
                    class="md:hidden text-zinc-500 hover:text-zinc-900 p-2 -mr-2 focus:outline-none"
                >
                    <div id="icon-menu-wrapper"><Menu class="w-6 h-6" /></div>
                    <div id="icon-close-wrapper" class="hidden">
                        <X class="w-6 h-6" />
                    </div>
                </button>
            </div>
        </nav>

        <!-- Mobile Menu Overlay -->
        <div
            id="mobile-menu"
            class="fixed inset-0 bg-white/98 dark:bg-zinc-950/98 backdrop-blur-xl z-[60] hidden flex-col justify-center items-center opacity-0 transition-opacity duration-300"
        >
            <nav class="flex flex-col items-center space-y-7 w-full px-6">
                <a
                    href="/#about"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >About</a
                >
                <a
                    href="/#news"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >News</a
                >
                <a
                    href="/cv"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >CV</a
                >
                <a
                    href="/#experience"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >Experience</a
                >
                <a
                    href="/projects"
                    class="mobile-link text-3xl font-montserrat font-semibold text-zinc-950 dark:text-white transition-colors capitalize"
                    >Projects</a
                >
                <a
                    href="/#blog"
                    class="mobile-link text-3xl font-montserrat font-light text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >Blog</a
                >
                <a
                    href="/gallery"
                    class="mobile-link text-3xl font-montserrat font-light text-zinc-800 dark:text-zinc-200 hover:text-blue-500 dark:hover:text-blue-400 transition-colors capitalize"
                    >Travel</a
                >

                <div class="pt-8 w-full max-w-[240px]">
                    <a
                        href="mailto:milad@natanzi.com"
                        class="mobile-link flex items-center justify-center px-6 py-4 text-[15px] font-montserrat font-medium tracking-[1px] text-white bg-zinc-900 dark:bg-white dark:text-zinc-900 rounded-full shadow-lg active:scale-95 transition-transform uppercase"
                    >
                        Let's Talk
                    </a>
                </div>
            </nav>
        </div>

        <main class="pt-32 pb-24 max-w-5xl mx-auto px-6">
            <!-- Header -->
            <header class="mb-16">
                <div class="flex items-center gap-3 mb-6">
                    <Cpu class="w-5 h-5 text-zinc-400" />
                    <span
                        class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 animate-pulse"
                        >Selected Works</span
                    >
                </div>

                <h1 class="text-4xl md:text-5xl font-extrabold text-zinc-900 dark:text-white mb-4 font-montserrat tracking-tight">
                    Project Portfolio
                </h1>
                <p
                    class="text-lg text-zinc-500 dark:text-zinc-400 font-light max-w-xl font-serif italic"
                >
                    These are the projects I have been involved in or have worked on.
                </p>
                <div class="mt-8 h-px bg-zinc-200 dark:bg-zinc-800"></div>
            </header>

            <!-- Projects Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
                {
                    projectsData.projects && projectsData.projects.map((project, index) => {
                        const IconComponent = getIcon(project.icon);
                        const theme = getColorTheme(index);
                        return (
                            <a
                                href={project.url}
                                target={project.url.startsWith('http') ? "_blank" : undefined}
                                rel={project.url.startsWith('http') ? "noopener noreferrer" : undefined}
                                class="group flex flex-col justify-between glass-card glass-card-hover rounded-2xl overflow-hidden"
                            >
                                <div>
                                    <!-- Project Image Header -->
                                    <div class="relative w-full aspect-video overflow-hidden border-b border-zinc-100 dark:border-zinc-800/50">
                                        {project.image ? (
                                            <img 
                                                src={project.image} 
                                                alt={project.title} 
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" 
                                            />
                                        ) : (
                                            <div class="w-full h-full bg-gradient-to-tr from-zinc-100 to-zinc-50 dark:from-zinc-900 dark:to-zinc-800 flex items-center justify-center">
                                                <IconComponent class="w-12 h-12 text-zinc-300 dark:text-zinc-700" />
                                            </div>
                                        )}
                                        
                                        <!-- Overlay Icon Badge -->
                                        <div class={`absolute top-4 left-4 p-2.5 rounded-xl border ${theme.bg} ${theme.text} ${theme.border} shadow-sm backdrop-blur-sm`}>
                                            <IconComponent class="w-5 h-5" />
                                        </div>

                                        <div class="absolute top-4 right-4 w-9 h-9 rounded-full border border-zinc-200 dark:border-zinc-700/50 bg-white/90 dark:bg-zinc-900/90 flex items-center justify-center group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:border-zinc-900 dark:group-hover:border-zinc-100 transition-colors shadow-sm backdrop-blur-sm">
                                            <ArrowUpRight class="w-4 h-4 text-zinc-505 dark:text-zinc-400 group-hover:text-white dark:group-hover:text-zinc-900 transition-colors" />
                                        </div>
                                    </div>
                                    
                                    <div class="p-6 md:p-8">
                                        <h2 class="text-2xl font-medium text-zinc-900 dark:text-zinc-100 mb-3 group-hover:text-blue-600 dark:group-hover:text-emerald-400 transition-colors">
                                            {project.title}
                                        </h2>
                                        <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed font-light mb-2 text-base">
                                            {project.description}
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-center flex-wrap gap-2 border-t border-zinc-100 dark:border-zinc-800/50 px-6 md:px-8 py-4 bg-zinc-50/50 dark:bg-zinc-900/30">
                                    {project.tags && project.tags.map((tag) => (
                                        <span class="px-2.5 py-1 bg-white dark:bg-zinc-900 border border-zinc-200/60 dark:border-zinc-800 rounded text-[10px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 uppercase">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </a>
                        );
                    })
                }
            </div>


        </main>

        <footer
            class="py-10 border-t border-zinc-200 dark:border-zinc-800 text-center text-sm font-medium text-zinc-500 dark:text-zinc-400"
        >
            © 2026 Milad Natanzi. Research. Innovate. Connect
        </footer>

        <script>
            // Mobile Menu Toggle Logic
            const mobileBtn = document.getElementById("mobile-menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");
            const iconMenuWrapper =
                document.getElementById("icon-menu-wrapper");
            const iconCloseWrapper =
                document.getElementById("icon-close-wrapper");
            const mobileLinks = document.querySelectorAll(".mobile-link");

            let menuOpen = false;

            document
                .getElementById("theme-toggle")
                ?.addEventListener("click", () => {
                    if (document.documentElement.classList.contains("dark")) {
                        document.documentElement.classList.remove("dark");
                        localStorage.setItem("theme", "light");
                    } else {
                        document.documentElement.classList.add("dark");
                        localStorage.setItem("theme", "dark");
                    }
                });

            function toggleMenu() {
                if (!mobileBtn) return;
                menuOpen = !menuOpen;
                if (menuOpen) {
                    mobileMenu.classList.remove("hidden");
                    setTimeout(() => {
                        mobileMenu.classList.remove("opacity-0");
                        mobileMenu.classList.add("opacity-100");
                        document.body.classList.add("no-scroll");
                        iconMenuWrapper.classList.add("hidden");
                        iconCloseWrapper.classList.remove("hidden");
                    }, 10);
                } else {
                    mobileMenu.classList.remove("opacity-100");
                    mobileMenu.classList.add("opacity-0");
                    document.body.classList.remove("no-scroll");
                    iconCloseWrapper.classList.add("hidden");
                    iconMenuWrapper.classList.remove("hidden");

                    setTimeout(() => {
                        mobileMenu.classList.add("hidden");
                    }, 300);
                }
            }

            if (mobileBtn) {
                mobileBtn.addEventListener("click", toggleMenu);
            }

            mobileLinks.forEach((link) => {
                link.addEventListener("click", () => {
                    if (menuOpen) toggleMenu();
                });
            });
        </script>
    </body>
</html>
